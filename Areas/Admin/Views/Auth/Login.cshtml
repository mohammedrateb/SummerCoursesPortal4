@*
    ═══════════════════════════════════════════════════════════════
      Admin/Auth/Login.cshtml — Indigo Command Center Theme
      • صفحة لوجين منفصلة بدون Layout.
      • Glassmorphism dark + aurora orbs + grid pattern.
      • Toggle password آمن (addEventListener — مفيش inline onclick).
      • Caps Lock detection.
      • Anti-forgery + asp-* helpers محفوظة.
      • Class prefix: aln-* (Admin Login).
      • صفر Backend.
    ═══════════════════════════════════════════════════════════════
*@
@model WebApplication1.ViewModels.Admin.AdminLoginViewModel
@{
    ViewData["Title"] = "تسجيل الدخول";
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>تسجيل دخول الإدارة</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@@400;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.0/dist/css/bootstrap.rtl.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" rel="stylesheet" />

    <style>
        :root{
            --aln-primary:#4F46E5;
            --aln-accent:#06B6D4;
            --aln-magenta:#EC4899;
            --aln-danger:#EF4444;
            --aln-ease: cubic-bezier(.22,.61,.36,1);
        }
        * { font-family:'Cairo', sans-serif; box-sizing:border-box; }
        html, body{ margin:0; padding:0; }
        body{
            min-height: 100vh;
            display:flex; align-items:center; justify-content:center;
            padding: 1.5rem;
            position: relative; overflow-x: hidden;
            background:
              radial-gradient(60% 60% at 80% 20%, rgba(79,70,229,.45), transparent 60%),
              radial-gradient(50% 50% at 20% 80%, rgba(6,182,212,.35), transparent 60%),
              radial-gradient(40% 40% at 70% 90%, rgba(236,72,153,.20), transparent 60%),
              linear-gradient(135deg, #0F172A 0%, #1E1B4B 50%, #0F172A 100%);
            color:#fff;
        }
        body::before{
            content:""; position:fixed; inset:0; pointer-events:none; z-index:0;
            background-image:
                linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
            background-size: 44px 44px;
            mask-image: radial-gradient(ellipse at 50% 50%, #000 30%, transparent 80%);
            -webkit-mask-image: radial-gradient(ellipse at 50% 50%, #000 30%, transparent 80%);
        }

        @@keyframes aln-float{
            0%,100%{ transform: translateY(0) rotate(0deg); }
            50%    { transform: translateY(-30px) rotate(180deg); }
        }
        @@keyframes aln-pulseRing{
            0%   { box-shadow: 0 0 0 0 rgba(6,182,212,.5); }
            70%  { box-shadow: 0 0 0 18px rgba(6,182,212,0); }
            100% { box-shadow: 0 0 0 0 rgba(6,182,212,0); }
        }
        @@keyframes aln-shine{ 0%{transform:translateX(-100%)} 60%{transform:translateX(100%)} 100%{transform:translateX(100%)} }
        @@keyframes aln-shake{ 0%,100%{transform:translateX(0)} 20%,60%{transform:translateX(-6px)} 40%,80%{transform:translateX(6px)} }
        @@keyframes aln-spin { to { transform: rotate(360deg); } }

        .aln-orb{
            position: fixed;
            border-radius: 50%;
            opacity: .14;
            animation: aln-float 8s ease-in-out infinite;
            filter: blur(8px);
            z-index: 0;
            pointer-events: none;
        }
        .aln-orb.o1{ width:320px; height:320px; background:#4F46E5; top:-110px; right:-110px; animation-delay:0s; }
        .aln-orb.o2{ width:220px; height:220px; background:#EC4899; bottom:-60px; left:-60px;  animation-delay:3s; }
        .aln-orb.o3{ width:160px; height:160px; background:#06B6D4; top:50%; left:8%; animation-delay:1.5s; }

        .aln-card{
            position: relative; z-index: 1;
            width: 100%; max-width: 440px;
            background: rgba(255,255,255,.06);
            backdrop-filter: blur(22px) saturate(160%);
            -webkit-backdrop-filter: blur(22px) saturate(160%);
            border: 1px solid rgba(255,255,255,.10);
            border-radius: 24px;
            padding: 2.75rem 2.5rem;
            box-shadow: 0 30px 60px rgba(0,0,0,.5);
            overflow: hidden;
        }
        .aln-card::before{
            content:""; position:absolute; left:0; right:0; top:0; height:4px;
            background: linear-gradient(90deg, var(--aln-primary), var(--aln-accent), var(--aln-magenta));
        }
        @@media (max-width: 480px){ .aln-card{ padding: 2rem 1.5rem; border-radius: 20px; } }

        .aln-logo{
            width: 84px; height: 84px;
            border-radius: 22px;
            background: linear-gradient(135deg, var(--aln-primary), var(--aln-accent));
            display:inline-flex; align-items:center; justify-content:center;
            margin: 0 auto 1.25rem;
            color:#fff; font-size: 2rem;
            box-shadow: 0 14px 30px rgba(79,70,229,.5);
            position: relative; overflow: hidden;
            animation: aln-pulseRing 2.5s ease-out infinite;
        }
        .aln-logo::after{
            content:""; position:absolute; inset:0;
            background: linear-gradient(120deg, transparent 30%, rgba(255,255,255,.5) 50%, transparent 70%);
            transform: translateX(-100%);
            animation: aln-shine 3.5s ease-in-out infinite;
        }
        .aln-title{
            font-weight: 800; color: #fff;
            margin: 0 0 .35rem; font-size: 1.5rem;
            letter-spacing: .3px;
        }
        .aln-sub{
            color: rgba(255,255,255,.55);
            font-size: .9rem; margin: 0;
        }

        .aln-alert{
            background: rgba(239,68,68,.15);
            border: 1px solid rgba(239,68,68,.3);
            border-radius: 12px;
            color: #FCA5A5;
            font-weight: 700;
            padding: .85rem 1rem;
            margin-bottom: 1.25rem;
            display: flex; align-items: flex-start; gap: 10px;
            animation: aln-shake .5s ease;
        }
        .aln-alert i{ flex-shrink: 0; margin-top: 2px; }
        .aln-alert .field-validation-error,
        .aln-alert ul{ margin: 0; padding-right: 0; }
        .aln-alert ul{ list-style: none; padding: 0; }

        .aln-label{
            display: flex; align-items: center; gap: 8px;
            color: rgba(255,255,255,.85);
            font-weight: 700; font-size: .9rem;
            margin-bottom: .55rem;
        }
        .aln-label i{
            color: var(--aln-accent); width: 16px; text-align: center;
        }

        .aln-input{
            background: rgba(255,255,255,.06);
            border: 1.5px solid rgba(255,255,255,.12);
            border-radius: 12px;
            padding: 13px 16px;
            color: #fff;
            font-size: 1rem;
            font-family: 'Cairo', sans-serif;
            width: 100%;
            transition: background .25s ease, border-color .25s ease, box-shadow .25s ease;
        }
        .aln-input:focus{
            background: rgba(255,255,255,.10);
            border-color: var(--aln-accent);
            box-shadow: 0 0 0 4px rgba(6,182,212,.2);
            outline: none;
            color: #fff;
        }
        .aln-input::placeholder{ color: rgba(255,255,255,.35); }

        .aln-pwwrap{ position: relative; }
        .aln-pwbtn{
            position: absolute; left: 10px; top: 50%;
            transform: translateY(-50%);
            background: rgba(255,255,255,.06);
            border: 1px solid rgba(255,255,255,.10);
            color: rgba(255,255,255,.7);
            width: 36px; height: 36px;
            border-radius: 8px;
            display: inline-flex; align-items: center; justify-content: center;
            cursor: pointer;
            transition: background .2s ease, color .2s ease;
        }
        .aln-pwbtn:hover{ background: rgba(6,182,212,.18); color: var(--aln-accent); }
        .aln-pwbtn:focus-visible{ outline: 2px solid var(--aln-accent); outline-offset: 2px; }
        .aln-input[type="password"], .aln-input[type="text"]#aln-password{ padding-left: 56px; }

        .aln-caps{
            display: none;
            color: var(--aln-magenta);
            font-size: .8rem;
            margin-top: .4rem;
            font-weight: 700;
            align-items: center; gap: 5px;
        }
        .aln-caps.is-on{ display: inline-flex; }

        .aln-btn{
            background: linear-gradient(135deg, var(--aln-primary), var(--aln-accent));
            color: #fff;
            border: none;
            border-radius: 12px;
            padding: 14px 16px;
            font-weight: 800; font-size: 1.05rem;
            font-family: 'Cairo', sans-serif;
            width: 100%;
            cursor: pointer;
            display: inline-flex; align-items: center; justify-content: center; gap: 10px;
            box-shadow: 0 10px 28px rgba(79,70,229,.45);
            position: relative; overflow: hidden; isolation: isolate;
            transition: transform .25s var(--aln-ease), box-shadow .25s ease, opacity .2s;
        }
        .aln-btn::after{
            content:""; position:absolute; inset:0;
            background: linear-gradient(120deg, transparent 30%, rgba(255,255,255,.35) 50%, transparent 70%);
            transform: translateX(-100%); transition: transform .8s ease;
        }
        .aln-btn:hover{ transform: translateY(-3px); box-shadow: 0 14px 36px rgba(79,70,229,.65); color:#fff; }
        .aln-btn:hover::after{ transform: translateX(100%); }
        .aln-btn:disabled{ opacity:.7; cursor:not-allowed; transform:none; }
        .aln-btn:focus-visible{ outline: 2px solid var(--aln-accent); outline-offset: 3px; }
        .aln-spinner{
            display:none; width:18px; height:18px;
            border: 2.5px solid rgba(255,255,255,.4); border-top-color:#fff;
            border-radius: 50%;
            animation: aln-spin .7s linear infinite;
        }
        .aln-btn.is-loading .aln-spinner{ display:inline-block; }
        .aln-btn.is-loading .aln-btn-icon{ display:none; }

        .aln-foot{
            text-align: center;
            margin-top: 1.5rem;
            color: rgba(255,255,255,.35);
            font-size: .82rem;
        }

        .text-danger.field-validation-error,
        span.text-danger.small{
            color: #FCA5A5 !important;
            font-weight: 600;
            display: block;
            margin-top: .35rem;
        }

        @@media (prefers-reduced-motion: reduce){
            *, *::before, *::after{
                animation: none !important; transition: none !important;
            }
        }
    </style>
</head>
<body>

    <!-- Floating background orbs -->
    <div class="aln-orb o1" aria-hidden="true"></div>
    <div class="aln-orb o2" aria-hidden="true"></div>
    <div class="aln-orb o3" aria-hidden="true"></div>

    <main class="aln-card animate__animated animate__fadeInUp" role="main">
        <!-- Logo -->
        <div class="text-center mb-4">
            <div class="aln-logo" aria-hidden="true">
                <i class="fas fa-shield-halved"></i>
            </div>
            <h1 class="aln-title">لوحة الإدارة</h1>
            <p class="aln-sub">أدخل بيانات تسجيل الدخول</p>
        </div>

        <!-- Error Message -->
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="aln-alert" role="alert">
                <i class="fas fa-circle-exclamation" aria-hidden="true"></i>
                <div>
                    @Html.ValidationSummary(false, "", new { @class = "mb-0" })
                </div>
            </div>
        }

        <!-- Form -->
        <form asp-area="Admin" asp-controller="Auth" asp-action="Login" method="post" id="aln-form" novalidate autocomplete="on">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="aln-label" asp-for="Username">
                    <i class="fas fa-user" aria-hidden="true"></i>
                    اسم المستخدم
                </label>
                <input asp-for="Username" class="aln-input"
                       placeholder="أدخل اسم المستخدم"
                       autocomplete="username"
                       autocapitalize="off"
                       spellcheck="false"
                       required />
                <span asp-validation-for="Username" class="text-danger small"></span>
            </div>

            <div class="mb-2">
                <label class="aln-label" asp-for="Password">
                    <i class="fas fa-lock" aria-hidden="true"></i>
                    كلمة المرور
                </label>
                <div class="aln-pwwrap">
                    <input asp-for="Password" type="password" class="aln-input"
                           placeholder="أدخل كلمة المرور"
                           id="aln-password"
                           autocomplete="current-password"
                           required />
                    <button type="button" class="aln-pwbtn"
                            id="aln-toggle"
                            aria-label="إظهار/إخفاء كلمة المرور"
                            aria-pressed="false">
                        <i class="fas fa-eye" id="aln-eye" aria-hidden="true"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
                <span class="aln-caps" id="aln-caps" role="status">
                    <i class="fas fa-arrow-up" aria-hidden="true"></i>
                    تنبيه: مفتاح Caps Lock مفعّل
                </span>
            </div>

            <button type="submit" class="aln-btn mt-4" id="aln-submit">
                <span class="aln-spinner" aria-hidden="true"></span>
                <i class="fas fa-right-to-bracket aln-btn-icon" aria-hidden="true"></i>
                <span>تسجيل الدخول</span>
            </button>
        </form>

        <div class="aln-foot">
            <i class="fas fa-shield-halved" aria-hidden="true"></i>
            هذه المنطقة مخصصة للمسؤولين فقط
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function () {
            'use strict';

            // ===== Toggle password visibility (آمن — addEventListener) =====
            var toggle = document.getElementById('aln-toggle');
            var input  = document.getElementById('aln-password');
            var eye    = document.getElementById('aln-eye');
            if (toggle && input && eye){
                toggle.addEventListener('click', function () {
                    var isPw = input.getAttribute('type') === 'password';
                    input.setAttribute('type', isPw ? 'text' : 'password');
                    toggle.setAttribute('aria-pressed', isPw ? 'true' : 'false');
                    eye.classList.toggle('fa-eye',      !isPw);
                    eye.classList.toggle('fa-eye-slash', isPw);
                    input.focus();
                });
            }

            // ===== Caps Lock detection =====
            var caps = document.getElementById('aln-caps');
            if (input && caps){
                function checkCaps(e){
                    if (e.getModifierState && e.getModifierState('CapsLock')){
                        caps.classList.add('is-on');
                    } else {
                        caps.classList.remove('is-on');
                    }
                }
                input.addEventListener('keydown', checkCaps);
                input.addEventListener('keyup',   checkCaps);
                input.addEventListener('blur', function () { caps.classList.remove('is-on'); });
            }

            // ===== Anti double-submit =====
            var form = document.getElementById('aln-form');
            var btn  = document.getElementById('aln-submit');
            if (form && btn){
                form.addEventListener('submit', function () {
                    btn.classList.add('is-loading');
                    btn.setAttribute('disabled', 'disabled');
                });
            }
        })();
    </script>
</body>
</html>
