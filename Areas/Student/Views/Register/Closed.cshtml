@{
    ViewData["Title"] = "التسجيل مغلق";
    var message = ViewBag.ClosedMessage as string ?? "التسجيل مغلق حالياً.";
}

<style>
    .rc-wrap{
        min-height:65vh; display:flex; align-items:center; justify-content:center;
        padding:2rem;
        background:radial-gradient(ellipse at 60% 0%, rgba(255,95,3,.07) 0%, transparent 55%),
                   radial-gradient(ellipse at 10% 100%, rgba(7,44,44,.07) 0%, transparent 55%);
    }
    .rc-card{
        max-width:540px; width:100%;
        background:#fff; border-radius:24px;
        box-shadow:0 24px 60px rgba(7,44,44,.13);
        padding:3rem 2.5rem; text-align:center;
        position:relative; overflow:hidden;
    }
    .rc-card::before{
        content:""; position:absolute; left:0; right:0; top:0; height:5px;
        background:linear-gradient(90deg,#FF5F03,#F59E0B,#EF4444);
    }
    .rc-icon-wrap{
        width:80px; height:80px; border-radius:22px; margin:0 auto 1.25rem;
        display:flex; align-items:center; justify-content:center;
        background:linear-gradient(135deg,#FF5F03,#F59E0B);
        box-shadow:0 14px 30px -8px rgba(255,95,3,.40);
        font-size:2rem; color:#fff;
        position:relative; overflow:hidden;
    }
    .rc-icon-wrap::after{
        content:""; position:absolute; inset:0;
        background:linear-gradient(120deg,transparent 30%,rgba(255,255,255,.22) 50%,transparent 70%);
    }
    .rc-title{
        font-weight:800; font-size:1.6rem; color:#072C2C; margin-bottom:.75rem;
    }

    /* ── رسالة تحذيرية بألوان العنبر/البرتقالي ── */
    .rc-msg{
        font-size:.97rem; line-height:1.8;
        background:linear-gradient(135deg,#FFF7ED,#FEF3C7);
        border:1.5px solid #FCD34D;
        border-radius:14px; padding:1rem 1.25rem;
        font-weight:600; color:#92400E; margin-bottom:2rem;
        display:flex; align-items:flex-start; gap:10px; text-align:right;
        position:relative; overflow:hidden;
    }
    .rc-msg::before{
        content:""; position:absolute; right:0; top:0; bottom:0; width:4px;
        background:linear-gradient(180deg,#FF5F03,#F59E0B);
    }
    .rc-msg i{ flex-shrink:0; margin-top:3px; color:#FF5F03; font-size:1.05rem; }

    .rc-divider{
        height:1px; background:linear-gradient(90deg,transparent,rgba(7,44,44,.12),transparent);
        margin:1.75rem 0;
    }
    .rc-hint{
        font-size:.84rem; color:#64748B; font-weight:500; margin-bottom:1.25rem;
    }

    /* ── الأزرار ── */
    .rc-actions{
        display:flex; gap:.85rem; justify-content:center; flex-wrap:wrap;
    }
    .rc-btn{
        display:inline-flex; align-items:center; gap:8px;
        padding:.8rem 1.6rem; border-radius:50px;
        text-decoration:none; font-weight:800; font-size:.93rem;
        transition:transform .25s ease,box-shadow .25s ease;
    }
    .rc-btn-home{
        background:linear-gradient(135deg,#072C2C,#1e6b6b);
        color:#fff;
        box-shadow:0 10px 24px -8px rgba(7,44,44,.45);
    }
    .rc-btn-home:hover{
        transform:translateY(-3px);
        box-shadow:0 16px 32px -8px rgba(7,44,44,.55);
        color:#fff;
    }
    .rc-btn-news{
        background:linear-gradient(135deg,#FF5F03,#ffb060);
        color:#fff;
        box-shadow:0 10px 24px -8px rgba(255,95,3,.40);
    }
    .rc-btn-news:hover{
        transform:translateY(-3px);
        box-shadow:0 16px 32px -8px rgba(255,95,3,.55);
        color:#fff;
    }
    @@media(prefers-reduced-motion:reduce){
        .rc-btn{ transition:none!important; }
    }
</style>

<div class="rc-wrap">
    <div class="rc-card">
        <div class="rc-icon-wrap" aria-hidden="true">
            <i class="fas fa-lock"></i>
        </div>
        <h1 class="rc-title">التسجيل مغلق حالياً</h1>
        <div class="rc-msg">
            <i class="fas fa-triangle-exclamation" aria-hidden="true"></i>
            <span>@message</span>
        </div>
        <div class="rc-divider"></div>
        <p class="rc-hint">تابع آخر الأخبار والإعلانات لمعرفة موعد فتح التسجيل</p>
        <div class="rc-actions">
            <a asp-area="Student" asp-controller="Home" asp-action="Index" class="rc-btn rc-btn-home">
                <i class="fas fa-house" aria-hidden="true"></i>
                الصفحة الرئيسية
            </a>
            <a asp-area="Student" asp-controller="News" asp-action="Index" class="rc-btn rc-btn-news">
                <i class="fas fa-newspaper" aria-hidden="true"></i>
                آخر الأخبار
            </a>
        </div>
    </div>
</div>
