<?xml version="1.0" encoding="utf-8"?>
<!--
  مهم: الملف ده بيستخدم لما المشروع يشتغل تحت IIS أو IIS Express
  (يعنى Visual Studio بيستخدم IIS Express افتراضياً).
  لو ماشى على Kestrel مباشرة (zero-IIS)، الإعدادات بتاعتك فى Program.cs
  هى اللى بتشتغل.

  بنرفع هنا:
  - حد رفع الملفات لـ 200 MB
  - timeout الطلب لـ 30 دقيقة (علشان الملفات الكبيرة)
-->
<configuration>
  <system.web>
    <!-- ASP.NET Classic timeout (4 ساعات) + حد رفع 200 MB -->
    <httpRuntime executionTimeout="14400" maxRequestLength="204800" />
  </system.web>
  <system.webServer>
    <security>
      <requestFiltering>
        <!-- 200 MB = 209,715,200 bytes -->
        <requestLimits maxAllowedContentLength="209715200" />
      </requestFiltering>
    </security>
    <!-- ASP.NET Core handler timeout (30 دقيقة) -->
    <aspNetCore requestTimeout="00:30:00" />
  </system.webServer>
</configuration>
