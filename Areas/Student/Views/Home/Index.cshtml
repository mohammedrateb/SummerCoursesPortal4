@*
    ═══════════════════════════════════════════════════════════════
      Vanilla JS — لا يستخدم eval ولا innerHTML على بيانات خارجية.
      • IntersectionObserver لظهور العناصر.
      • Counter animation للأرقام.
      • Spotlight (mousemove) على البطاقات.
      • Magnetic effect خفيف على الأزرار.
      • يحترم prefers-reduced-motion.
    ═══════════════════════════════════════════════════════════════
*@
@section Scripts {
    <script>
        (function () {
            'use strict';

            var prefersReduced = window.matchMedia &&
                window.matchMedia('(prefers-reduced-motion: reduce)').matches;

            // 1) Reveal on scroll
            var revealTargets = document.querySelectorAll('.scp-reveal, .scp-reveal-zoom, .scp-reveal-right, .scp-reveal-left');
            if (prefersReduced || !('IntersectionObserver' in window)) {
                revealTargets.forEach(function (el) { el.classList.add('scp-in'); });
            } else {
                var io = new IntersectionObserver(function (entries) {
                    entries.forEach(function (entry) {
                        if (entry.isIntersecting) {
                            entry.target.classList.add('scp-in');
                            io.unobserve(entry.target);
                        }
                    });
                }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
                revealTargets.forEach(function (el) { io.observe(el); });
            }

            // 2) Counter animation (آمن: textContent فقط)
            var counters = document.querySelectorAll('[data-scp-counter]');
            function animateCount(el) {
                var target = parseInt(el.getAttribute('data-scp-counter'), 10) || 0;
                var suffix = el.getAttribute('data-scp-suffix') || '';
                var duration = 1400;
                var startTs = null;
                function step(ts) {
                    if (!startTs) startTs = ts;
                    var p = Math.min((ts - startTs) / duration, 1);
                    var eased = 1 - Math.pow(1 - p, 3);
                    el.textContent = Math.round(target * eased) + suffix;
                    if (p < 1) requestAnimationFrame(step);
                }
                requestAnimationFrame(step);
            }
            if (prefersReduced) {
                counters.forEach(function (el) {
                    el.textContent = el.getAttribute('data-scp-counter') + (el.getAttribute('data-scp-suffix') || '');
                });
            } else if ('IntersectionObserver' in window) {
                var ioCount = new IntersectionObserver(function (entries) {
                    entries.forEach(function (entry) {
                        if (entry.isIntersecting) {
                            animateCount(entry.target);
                            ioCount.unobserve(entry.target);
                        }
                    });
                }, { threshold: 0.4 });
                counters.forEach(function (el) { ioCount.observe(el); });
            } else {
                counters.forEach(animateCount);
            }

            // 3) Spotlight follow on cards
            if (!prefersReduced) {
                var spots = document.querySelectorAll('.scp-spotlight');
                spots.forEach(function (card) {
                    card.addEventListener('mousemove', function (e) {
                        var r = card.getBoundingClientRect();
                        var x = ((e.clientX - r.left) / r.width) * 100;
                        var y = ((e.clientY - r.top) / r.height) * 100;
                        card.style.setProperty('--mx', x + '%');
                        card.style.setProperty('--my', y + '%');
                    });
                });
            }

            // 4) Tilt 3D خفيف
            if (!prefersReduced) {
                var tilts = document.querySelectorAll('.scp-tilt');
                tilts.forEach(function (el) {
                    el.addEventListener('mousemove', function (e) {
                        var r = el.getBoundingClientRect();
                        var px = (e.clientX - r.left) / r.width  - 0.5;
                        var py = (e.clientY - r.top)  / r.height - 0.5;
                        var max = 6; // درجات
                        el.style.transform = 'perspective(700px) rotateX(' + (-py * max) + 'deg) rotateY(' + (px * max) + 'deg) translateY(-6px)';
                    });
                    el.addEventListener('mouseleave', function () {
                        el.style.transform = '';
                    });
                });
            }

            // 5) Magnetic buttons (انجذاب خفيف للمؤشر)
            if (!prefersReduced && window.matchMedia('(pointer:fine)').matches) {
                var magnets = document.querySelectorAll('.scp-magnet');
                magnets.forEach(function (btn) {
                    btn.addEventListener('mousemove', function (e) {
                        var r = btn.getBoundingClientRect();
                        var x = e.clientX - r.left - r.width / 2;
                        var y = e.clientY - r.top  - r.height / 2;
                        btn.style.transform = 'translate(' + (x * 0.15) + 'px,' + (y * 0.2) + 'px)';
                    });
                    btn.addEventListener('mouseleave', function () {
                        btn.style.transform = '';
                    });
                });
            }
        })();
    </script>
}