@*
    ═══════════════════════════════════════════════════════════════
      Admin/Students/Print.cshtml — Indigo Command Center Theme
      • صفحة طباعة منفصلة بدون Layout.
      • معدّة للطباعة (print-color-adjust + media query).
      • أزرار طباعة/إغلاق آمنة (addEventListener — مفيش inline onclick).
      • Logo + شريط ملوّن + تذييل احترافي.
      • Class prefix: apr-* (Admin Print).
      • صفر Backend.
    ═══════════════════════════════════════════════════════════════
*@
@model IEnumerable<WebApplication1.Models.Student>
@{
    Layout = null;
    var total  = Model.Count();
    var paid   = Model.Count(s => s.PaymentStatus);
    var unpaid = Model.Count(s => !s.PaymentStatus);
}
<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>طباعة بيانات الطلاب</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@@400;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
        :root{
            --apr-primary:#4F46E5;
            --apr-accent:#06B6D4;
            --apr-magenta:#EC4899;
            --apr-success:#10B981;
            --apr-danger:#EF4444;
            --apr-text:#0F172A;
            --apr-muted:#64748B;
            --apr-border:#E2E8F0;
        }
        * { font-family: 'Cairo', sans-serif; margin: 0; padding: 0; box-sizing: border-box; }
        body{
            padding: 30px 24px;
            background: #fff;
            color: var(--apr-text);
        }

        /* ===== Top Action Bar (لا تظهر عند الطباعة) ===== */
        .apr-actions{
            text-align: center;
            margin-bottom: 24px;
            display: flex;
            justify-content: center;
            gap: 12px;
            flex-wrap: wrap;
        }
        .apr-btn{
            border: none;
            padding: 10px 26px;
            border-radius: 10px;
            font-family: 'Cairo', sans-serif;
            font-size: 14px;
            font-weight: 800;
            cursor: pointer;
            color: #fff;
            display: inline-flex; align-items: center; gap: 8px;
            box-shadow: 0 8px 18px -8px rgba(0,0,0,.3);
            transition: transform .25s ease, box-shadow .25s ease, opacity .2s;
        }
        .apr-btn:hover{ transform: translateY(-2px); }
        .apr-btn:focus-visible{ outline: 2px solid var(--apr-accent); outline-offset: 2px; }
        .apr-btn-print{ background: linear-gradient(135deg, var(--apr-primary), var(--apr-accent)); }
        .apr-btn-close{ background: linear-gradient(135deg, var(--apr-danger), #B91C1C); }

        /* ===== Header ===== */
        .apr-header{
            text-align: center;
            margin-bottom: 22px;
            padding-bottom: 18px;
            position: relative;
            border-bottom: 1px solid var(--apr-border);
        }
        .apr-header::after{
            content:""; position: absolute;
            left: 50%; bottom: -2px;
            transform: translateX(-50%);
            width: 200px; height: 4px;
            border-radius: 2px;
            background: linear-gradient(90deg, var(--apr-primary), var(--apr-accent), var(--apr-magenta));
        }
        .apr-logo{
            display: inline-flex; align-items: center; justify-content: center;
            width: 50px; height: 50px;
            border-radius: 12px;
            background: linear-gradient(135deg, var(--apr-primary), var(--apr-accent));
            color: #fff; font-size: 1.3rem;
            margin-bottom: 10px;
        }
        .apr-header h2{
            color: var(--apr-text);
            font-size: 22px;
            font-weight: 800;
            margin: 0 0 4px;
        }
        .apr-header p{
            color: var(--apr-muted);
            font-size: 13px;
            font-weight: 600;
        }
        .apr-header p i{ color: var(--apr-accent); margin-left: 4px; }

        /* ===== Stats ===== */
        .apr-stats{
            display: flex;
            gap: 14px;
            margin-bottom: 22px;
            justify-content: center;
            flex-wrap: wrap;
        }
        .apr-stat{
            padding: 12px 22px;
            border-radius: 10px;
            font-weight: 800;
            font-size: 14px;
            display: inline-flex; align-items: center; gap: 8px;
            min-width: 160px;
            justify-content: center;
            border: 1.5px solid;
        }
        .apr-stat i{ font-size: 16px; }
        .apr-stat-total  { background:#EEF2FF; color:#4338CA; border-color:#C7D2FE; }
        .apr-stat-paid   { background:#ECFDF5; color:#047857; border-color:#A7F3D0; }
        .apr-stat-unpaid { background:#FEF2F2; color:#B91C1C; border-color:#FECACA; }

        /* ===== Table ===== */
        .apr-table-wrap{
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid var(--apr-border);
        }
        table{
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }
        thead th{
            background: linear-gradient(135deg, #1E1B4B 0%, #0F172A 100%);
            color: #fff;
            padding: 13px 10px;
            text-align: right;
            font-weight: 800;
            white-space: nowrap;
            font-size: 13px;
        }
        tbody td{
            border-bottom: 1px solid #F1F5F9;
            padding: 10px;
            text-align: right;
            color: #334155;
            vertical-align: middle;
        }
        tbody tr:nth-child(even){ background: #F8FAFC; }
        tbody tr:last-child td{ border-bottom: none; }

        /* ===== Badges ===== */
        .apr-badge{
            display: inline-flex; align-items: center; gap: 4px;
            padding: 4px 10px;
            border-radius: 50px;
            font-weight: 800;
            font-size: 12px;
        }
        .apr-badge-paid   { background:#ECFDF5; color:#047857; border:1px solid #A7F3D0; }
        .apr-badge-unpaid { background:#FEF2F2; color:#B91C1C; border:1px solid #FECACA; }

        /* ===== Empty state ===== */
        .apr-empty{
            text-align: center;
            padding: 50px 20px;
            color: var(--apr-muted);
        }
        .apr-empty i{ font-size: 3rem; color: var(--apr-border); margin-bottom: 14px; display:block; }

        /* ===== Footer ===== */
        .apr-footer{
            margin-top: 28px;
            padding-top: 16px;
            border-top: 2px dashed var(--apr-border);
            text-align: center;
            color: #94A3B8;
            font-size: 12px;
            font-weight: 600;
        }
        .apr-footer i{ color: var(--apr-primary); margin-left: 4px; }

        /* ===== Print ===== */
        @@media print{
            .no-print, .apr-actions{ display: none !important; }
            body{ padding: 12px; }
            thead th{
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
                color-adjust: exact;
            }
            .apr-table-wrap, .apr-stat, .apr-badge, .apr-logo, .apr-header::after{
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
                color-adjust: exact;
            }
            tbody tr{ break-inside: avoid; page-break-inside: avoid; }
            .apr-header{ page-break-after: avoid; }
        }
    </style>
</head>
<body>

    <!-- أزرار فوق - بتختفي عند الطباعة -->
    <div class="apr-actions no-print">
        <button type="button" class="apr-btn apr-btn-print" id="apr-print">
            <i class="fas fa-print" aria-hidden="true"></i>
            طباعة / حفظ PDF
        </button>
        <button type="button" class="apr-btn apr-btn-close" id="apr-close">
            <i class="fas fa-xmark" aria-hidden="true"></i>
            إغلاق
        </button>
    </div>

    <!-- Header -->
    <div class="apr-header">
        <div class="apr-logo" aria-hidden="true">
            <i class="fas fa-graduation-cap"></i>
        </div>
        <h2>بيانات الطلاب</h2>
        <p>
            <i class="fas fa-calendar-day" aria-hidden="true"></i>
            تاريخ الطباعة: @DateTime.Now.ToString("yyyy/MM/dd - HH:mm")
        </p>
    </div>

    <!-- Stats -->
    <div class="apr-stats">
        <div class="apr-stat apr-stat-total">
            <i class="fas fa-users" aria-hidden="true"></i>
            إجمالي: @total
        </div>
        <div class="apr-stat apr-stat-paid">
            <i class="fas fa-circle-check" aria-hidden="true"></i>
            تم الدفع: @paid
        </div>
        <div class="apr-stat apr-stat-unpaid">
            <i class="fas fa-circle-xmark" aria-hidden="true"></i>
            لم يتم الدفع: @unpaid
        </div>
    </div>

    <!-- Table -->
    @if (total == 0)
    {
        <div class="apr-empty">
            <i class="fas fa-inbox" aria-hidden="true"></i>
            <h5 style="font-weight:800;color:#475569;margin-bottom:8px">لا توجد بيانات للعرض</h5>
            <p>لم يتم العثور على أي طلاب يطابقون معايير الفلترة الحالية.</p>
        </div>
    }
    else
    {
        <div class="apr-table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>الاسم</th>
                        <th>الرقم القومي</th>
                        <th>الموبايل</th>
                        <th>المستوى</th>
                        <th>الشعبة</th>
                        <th>المادة 1</th>
                        <th>المادة 2</th>
                        <th>المادة 3</th>
                        <th>المادة 4</th>
                        <th>المادة 5</th>
                        <th>حالة الدفع</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int i = 1; }
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td>@i</td>
                            <td>@s.FullName</td>
                            <td dir="ltr">@s.NationalId</td>
                            <td dir="ltr">@s.PhoneNumber</td>
                            <td>@s.Level?.Name</td>
                            <td>@s.Division?.Name</td>
                            <td>@s.Subject1</td>
                            <td>@(s.Subject2 ?? "-")</td>
                            <td>@(s.Subject3 ?? "-")</td>
                            <td>@(s.Subject4 ?? "-")</td>
                            <td>@(s.Subject5 ?? "-")</td>
                            <td>
                                @if (s.PaymentStatus)
                                {
                                    <span class="apr-badge apr-badge-paid">
                                        <i class="fas fa-circle-check" aria-hidden="true"></i>
                                        تم
                                    </span>
                                }
                                else
                                {
                                    <span class="apr-badge apr-badge-unpaid">
                                        <i class="fas fa-circle-xmark" aria-hidden="true"></i>
                                        لم يتم
                                    </span>
                                }
                            </td>
                        </tr>
                        i++;
                    }
                </tbody>
            </table>
        </div>
    }

    <!-- Footer -->
    <div class="apr-footer">
        <i class="fas fa-shield-halved" aria-hidden="true"></i>
       Summer Courses Portal    @DateTime.Now.Year
    </div>

    <script>
        (function () {
            'use strict';
            var btnPrint = document.getElementById('apr-print');
            var btnClose = document.getElementById('apr-close');
            if (btnPrint){
                btnPrint.addEventListener('click', function () { window.print(); });
            }
            if (btnClose){
                btnClose.addEventListener('click', function () {
                    // window.close يشتغل بس لو الصفحة فُتحت بـ window.open
                    try { window.close(); } catch (e) { /* تجاهل */ }
                    // Fallback: ارجع للصفحة السابقة
                    if (!window.closed){
                        if (document.referrer){ window.location.href = document.referrer; }
                        else { window.history.back(); }
                    }
                });
            }
        })();
    </script>

</body>
</html>
