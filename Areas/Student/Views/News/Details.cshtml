@model WebApplication1.Models.Post
@{
    ViewData["Title"] = Model.Title;
    var images = Model.Attachments.Where(a => a.Type == WebApplication1.Models.AttachmentType.Image).ToList();
    var videos = Model.Attachments.Where(a => a.Type == WebApplication1.Models.AttachmentType.Video).ToList();
    var pdfs   = Model.Attachments.Where(a => a.Type == WebApplication1.Models.AttachmentType.PDF).ToList();
    var files  = Model.Attachments.Where(a => a.Type == WebApplication1.Models.AttachmentType.File).ToList();
    var embeds = Model.Attachments.Where(a => a.Type == WebApplication1.Models.AttachmentType.Embed).ToList();
}

@*
    ═══════════════════════════════════════════════════════════════
      ملاحظات هامة:
      • صفر تعديلات على الـ Backend / Model.
      • نفس asp-area / asp-controller / asp-action / asp-route-id.
      • كل بيانات المستخدم تُعرض عبر Razor (@) → ترميز HTML تلقائي → آمن من XSS.
      • الـ JS لا يستخدم innerHTML على أي بيانات من السيرفر، فقط .src/.alt
        (وهي خصائص آمنة لأن المتصفح لا يفسرها كـ HTML).
      • تم استبدال onclick="" inline بمستمعي أحداث (Event Listeners) لفصل
        السلوك عن البنية، مع إبقاء data-* attributes فقط.
      • يحترم prefers-reduced-motion.
    ═══════════════════════════════════════════════════════════════
*@

<!-- ═══════════════════════════════════════
     ENHANCED DETAILS DESIGN
═══════════════════════════════════════ -->
<style>
    /* ========== Tokens ========== */
    :root {
        --primary: #072C2C; --primary-hover: #0a3d3d; --primary-light: #105555;
        --secondary: #FF5F03; --secondary-hover: #e55400;
        --surface: #ffffff; --surface-alt: #f8fafc;
        --text: #111827; --text-muted: #6B7280;
        --border: #E5E7EB;
        --shadow-sm: 0 4px 8px -2px rgba(7,44,44,.06);
        --shadow-md: 0 12px 28px -10px rgba(7,44,44,.18);
        --shadow-lg: 0 24px 50px -16px rgba(7,44,44,.28);
        --radius: 18px; --radius-sm: 12px; --radius-lg: 26px;

        --dx-ease: cubic-bezier(.22,.61,.36,1);
        --dx-bounce: cubic-bezier(.34,1.56,.64,1);
        --dx-glass-bg: rgba(255,255,255,.65);
        --dx-grad-primary: linear-gradient(135deg,#072C2C 0%,#1e6b6b 100%);
        --dx-grad-accent:  linear-gradient(135deg,#FF5F03 0%,#ffb060 100%);
        --dx-grad-mix:     linear-gradient(120deg,#072C2C,#1e6b6b 45%,#FF5F03);
    }

    /* ========== Keyframes ========== */
    @@keyframes dx-fadeUp  { from{opacity:0;transform:translateY(28px)} to{opacity:1;transform:translateY(0)} }
    @@keyframes dx-zoomIn  { from{opacity:0;transform:scale(.93)}        to{opacity:1;transform:scale(1)} }
    @@keyframes dx-float   { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-10px)} }
    @@keyframes dx-shimmer { 0%{background-position:-200% 0} 100%{background-position:200% 0} }
    @@keyframes dx-spinSlow{ from{transform:rotate(0)} to{transform:rotate(360deg)} }
    @@keyframes dx-pulse   { 0%,100%{box-shadow:0 0 0 0 rgba(255,95,3,.45)} 50%{box-shadow:0 0 0 12px rgba(255,95,3,0)} }
    @@keyframes dx-lbIn    { from{opacity:0;transform:scale(.92)} to{opacity:1;transform:scale(1)} }

    /* ========== Reveal ========== */
    .dx-reveal,.dx-reveal-zoom { opacity:0; will-change:opacity, transform; }
    .dx-reveal.dx-in       { animation: dx-fadeUp .8s var(--dx-ease) forwards; }
    .dx-reveal-zoom.dx-in  { animation: dx-zoomIn .75s var(--dx-ease) forwards; }
    .dx-d1{animation-delay:.08s}.dx-d2{animation-delay:.16s}.dx-d3{animation-delay:.24s}
    .dx-d4{animation-delay:.32s}.dx-d5{animation-delay:.40s}

    /* ========== Reading Progress Bar ========== */
    .dx-progress{
        position: fixed; top:0; right:0; height:3px; width:0%;
        background: var(--dx-grad-accent);
        z-index: 10000; pointer-events:none;
        transition: width .1s linear;
        box-shadow: 0 0 12px rgba(255,95,3,.6);
    }

    /* ========== Hero ========== */
    .details-hero-enterprise {
        background: var(--dx-grad-primary);
        padding: 4.5rem 0 3.5rem;
        position: relative; overflow: hidden;
        border-bottom-left-radius: 36px;
        border-bottom-right-radius: 36px;
        isolation: isolate;
    }
    .details-hero-enterprise::before{
        content:""; position:absolute; inset:-15% auto auto -10%;
        width:480px; height:480px;
        background: radial-gradient(circle, rgba(255,95,3,.30), transparent 60%);
        filter: blur(40px); animation: dx-float 12s ease-in-out infinite;
        z-index:-1;
    }
    .details-hero-enterprise::after{
        content:""; position:absolute; inset:auto -10% -25% auto;
        width:380px; height:380px;
        background: radial-gradient(circle, rgba(30,107,107,.55), transparent 65%);
        filter: blur(40px); animation: dx-float 14s ease-in-out infinite reverse;
        z-index:-1;
    }
    .dx-hero-grid{
        position:absolute; inset:0; pointer-events:none; z-index:-1;
        background-image:
          linear-gradient(rgba(255,255,255,.05) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,.05) 1px, transparent 1px);
        background-size: 44px 44px;
        mask-image: radial-gradient(ellipse at center, #000 30%, transparent 75%);
        -webkit-mask-image: radial-gradient(ellipse at center, #000 30%, transparent 75%);
    }

    .back-link{
        display:inline-flex; align-items:center; gap:8px;
        padding: 8px 16px; border-radius:50px;
        background: rgba(255,255,255,.10);
        backdrop-filter: blur(10px) saturate(140%);
        -webkit-backdrop-filter: blur(10px) saturate(140%);
        border: 1px solid rgba(255,255,255,.20);
        color: rgba(255,255,255,.92); text-decoration:none; font-weight:600; font-size:.9rem;
        transition: transform .35s var(--dx-ease), background .3s ease, color .3s ease;
        margin-bottom: 1.75rem;
    }
    .back-link:hover{
        color:#fff; background: rgba(255,255,255,.18);
        transform: translateX(-6px);
    }
    .back-link i{ transition: transform .3s ease; }
    .back-link:hover i{ transform: translateX(-3px); }

    .hero-badges{ display:flex; gap:8px; flex-wrap:wrap; margin-bottom: 1.25rem; }
    .badge-pill{
        display:inline-flex; align-items:center; gap:6px;
        padding: 7px 14px;
        background: rgba(255,255,255,.12);
        backdrop-filter: blur(8px) saturate(140%);
        -webkit-backdrop-filter: blur(8px) saturate(140%);
        border: 1px solid rgba(255,255,255,.22);
        border-radius: 50px; color:#fff; font-size:.85rem; font-weight:600;
        transition: transform .3s ease, background .3s ease;
    }
    .badge-pill:hover{ transform: translateY(-2px); background: rgba(255,255,255,.20); }
    .badge-pill.dx-pulse{ animation: dx-pulse 2.6s ease-out infinite; }

    .hero-title{
        font-family:'Oswald', sans-serif; font-size:2.4rem; font-weight:700;
        line-height:1.3; max-width: 820px; margin:0;
        background-image: linear-gradient(120deg, #fff, #ffd9b8 60%, #fff);
        background-size: 220% auto;
        -webkit-background-clip: text; background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: dx-shimmer 8s linear infinite;
    }

    /* Inline meta row under title */
    .dx-hero-meta{
        margin-top: 1rem; display:flex; gap:18px; flex-wrap:wrap;
        color: rgba(255,255,255,.75); font-size: .9rem; font-weight:500;
    }
    .dx-hero-meta span{ display:inline-flex; align-items:center; gap:6px; }

    /* ========== Content Blocks ========== */
    .content-block-enterprise{
        position: relative;
        background:
          linear-gradient(var(--surface), var(--surface)) padding-box,
          linear-gradient(135deg, rgba(7,44,44,.15), rgba(255,95,3,.18)) border-box;
        border:1px solid transparent;
        border-radius: var(--radius);
        box-shadow: var(--shadow-sm);
        margin-bottom: 1.5rem; overflow:hidden;
        transition: transform .45s var(--dx-ease), box-shadow .45s ease;
    }
    .content-block-enterprise:hover{ transform: translateY(-4px); box-shadow: var(--shadow-md); }

    .block-header{
        padding: 1rem 1.5rem; display:flex; align-items:center; gap:12px;
        border-bottom: 1px solid var(--border);
        background: linear-gradient(135deg, var(--surface-alt), #fff);
    }
    .header-icon{
        width:38px; height:38px; border-radius: var(--radius-sm);
        display:flex; align-items:center; justify-content:center;
        font-size:.95rem; color:#fff; flex-shrink:0;
        box-shadow: 0 8px 18px -8px rgba(0,0,0,.35);
        transition: transform .45s var(--dx-bounce);
    }
    .content-block-enterprise:hover .header-icon{ transform: rotate(-8deg) scale(1.08); }
    .header-title{
        font-family:'Oswald', sans-serif; font-weight:700;
        color: var(--primary); font-size: 1.05rem; margin:0;
    }
    .header-count{
        margin-right: auto;
        background: var(--surface-alt); color: var(--text-muted);
        font-size:.78rem; font-weight:700;
        padding: 4px 10px; border-radius: 999px; border:1px solid var(--border);
    }
    .block-body{ padding: 1.5rem; }

    /* ========== Gallery ========== */
    .gallery-grid{ display:grid; gap:12px; }
    .gallery-grid.single{ grid-template-columns: 1fr; }
    .gallery-grid.double{ grid-template-columns: repeat(2, 1fr); }
    .gallery-grid.triple{ grid-template-columns: 1fr; }
    @@media(min-width:640px){ .gallery-grid.triple{ grid-template-columns: 1fr 1fr; } }
    .gallery-grid.multi{ grid-template-columns: repeat(2, 1fr); }

    .gallery-item{
        border-radius: var(--radius-sm); overflow:hidden; position:relative;
        cursor: zoom-in; background: var(--surface-alt);
        box-shadow: var(--shadow-sm);
        transition: transform .5s var(--dx-ease), box-shadow .5s ease;
    }
    .gallery-item:hover{ transform: translateY(-4px); box-shadow: var(--shadow-md); }
    .gallery-item img{
        width:100%; height:220px; object-fit: cover; display:block;
        transition: transform .8s var(--dx-ease);
    }
    .gallery-item.featured img{ height:340px; }
    .gallery-item:hover img{ transform: scale(1.07); }
    .gallery-item .zoom-btn{
        position:absolute; top:12px; right:12px; width:38px; height:38px;
        background: rgba(255,255,255,.95);
        border-radius:50%;
        display:flex; align-items:center; justify-content:center;
        color: var(--primary);
        opacity:0; transform: translateY(-6px);
        transition: opacity .35s ease, transform .35s var(--dx-bounce);
        box-shadow: var(--shadow-md);
    }
    .gallery-item:hover .zoom-btn{ opacity:1; transform: translateY(0); }
    .gallery-item::after{
        content:""; position:absolute; inset:0;
        background: linear-gradient(to top, rgba(7,44,44,.55), transparent 55%);
        opacity:0; transition: opacity .35s ease; pointer-events:none;
    }
    .gallery-item:hover::after{ opacity:1; }
    .gallery-overlay{
        position:absolute; inset:0; display:flex; align-items:center; justify-content:center;
        background: rgba(7,44,44,.65); color:#fff; font-weight:800; font-size:1.6rem;
        opacity:0; transition: opacity .35s ease;
        backdrop-filter: blur(2px);
    }
    .gallery-item.has-more:hover .gallery-overlay{ opacity:1; }

    /* ========== Post Content ========== */
    .post-content{
        font-size: 1.08rem; line-height: 2; color: var(--text);
        white-space: pre-line; padding: .5rem 0;
    }
    .post-content p{ margin-bottom: 1.25rem; }
    /* أول حرف مزخرف (drop cap) */
    .post-content::first-letter{
        font-size: 2.6rem; font-weight: 800; color: var(--primary);
        float: right; line-height: 1; padding: 4px 10px 0 10px;
        margin: 6px 0 0 8px;
        background: linear-gradient(135deg, rgba(255,95,3,.12), rgba(7,44,44,.04));
        border-radius: 12px;
        font-family: 'Oswald', sans-serif;
    }

    /* ========== File / Attachment Cards ========== */
    .file-card{
        display:flex; align-items:center; justify-content:space-between;
        padding: 1rem 1.1rem; border-radius: var(--radius-sm);
        background:
          linear-gradient(var(--surface-alt), var(--surface-alt)) padding-box,
          linear-gradient(135deg, rgba(7,44,44,.10), rgba(255,95,3,.14)) border-box;
        border:1px solid transparent;
        transition: transform .35s var(--dx-ease), box-shadow .35s ease, border-color .35s ease;
        margin-bottom: 12px; flex-wrap: wrap; gap: 12px;
        position: relative; overflow: hidden;
    }
    .file-card::before{
        content:""; position:absolute; inset:0 auto 0 0; width:4px;
        background: var(--dx-grad-accent);
        transform: scaleY(0); transform-origin: bottom;
        transition: transform .4s var(--dx-ease);
    }
    .file-card:hover{ transform: translateX(-4px); box-shadow: var(--shadow-sm); }
    .file-card:hover::before{ transform: scaleY(1); transform-origin: top; }

    .file-info{ display:flex; align-items:center; gap:14px; min-width:0; }
    .file-icon{
        width:46px; height:46px; border-radius: 12px;
        display:flex; align-items:center; justify-content:center;
        font-size:1.25rem; color:#fff; flex-shrink:0;
        box-shadow: 0 8px 18px -8px rgba(0,0,0,.4);
        transition: transform .45s var(--dx-bounce);
    }
    .file-card:hover .file-icon{ transform: rotate(-8deg) scale(1.08); }
    .file-name{
        font-weight:700; color: var(--text); margin:0; font-size:.96rem;
        word-break: break-word;
    }
    .file-type{ color: var(--text-muted); font-size:.8rem; }

    .btn-file{
        display:inline-flex; align-items:center; gap:6px;
        padding: 9px 18px; border-radius: 50px;
        font-size:.86rem; font-weight:700; text-decoration:none;
        transition: transform .35s var(--dx-ease), box-shadow .35s ease, background-color .3s ease;
        position: relative; overflow:hidden;
    }
    .btn-file::after{
        content:""; position:absolute; inset:0;
        background: linear-gradient(120deg, transparent 30%, rgba(255,255,255,.35) 50%, transparent 70%);
        transform: translateX(-100%); transition: transform .7s ease; pointer-events:none;
    }
    .btn-file:hover{ transform: translateY(-2px); box-shadow: 0 10px 22px -8px rgba(0,0,0,.3); }
    .btn-file:hover::after{ transform: translateX(100%); }
    .btn-file.primary{ background: var(--secondary); color:#fff; }
    .btn-file.primary:hover{ background: var(--secondary-hover); color:#fff; }
    .btn-file.secondary{ background: var(--primary); color:#fff; }
    .btn-file.secondary:hover{ background: var(--primary-hover); color:#fff; }

    /* ========== Embeds & Videos ========== */
    .embed-wrapper{
        position:relative; padding-bottom:56.25%; height:0; overflow:hidden;
        border-radius: var(--radius-sm); margin-bottom:1rem;
        box-shadow: var(--shadow-sm);
        background:#000;
    }
    .embed-wrapper iframe{
        position:absolute; top:0; left:0; width:100%; height:100%;
        border:0; border-radius: var(--radius-sm);
    }
    .dx-video{
        width:100%; border-radius: var(--radius-sm);
        background:#000; box-shadow: var(--shadow-sm);
        transition: transform .4s var(--dx-ease), box-shadow .4s ease;
    }
    .dx-video:hover{ transform: translateY(-3px); box-shadow: var(--shadow-md); }

    /* ========== Lightbox (محسّن: تنقّل + عدّاد + لوحة مفاتيح) ========== */
    .lightbox-enterprise{
        display:none; position:fixed; inset:0; z-index: 9999;
        background: rgba(0,0,0,.93);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        align-items:center; justify-content:center; padding: 20px;
        opacity: 0; transition: opacity .3s ease;
    }
    .lightbox-enterprise.active{ display:flex; opacity:1; }
    .lightbox-enterprise img{
        max-width: 92vw; max-height: 86vh;
        border-radius: var(--radius);
        box-shadow: 0 0 80px rgba(0,0,0,.6);
        animation: dx-lbIn .35s var(--dx-ease);
    }
    .lb-close, .lb-nav{
        position:absolute; width:48px; height:48px;
        background: rgba(255,255,255,.14);
        border:1px solid rgba(255,255,255,.18);
        border-radius:50%; color:#fff;
        font-size:1.1rem; cursor:pointer;
        display:flex; align-items:center; justify-content:center;
        transition: transform .35s var(--dx-ease), background .3s ease;
    }
    .lb-close{ top: 20px; left: 20px; }
    .lb-close:hover{ background: rgba(255,255,255,.28); transform: rotate(90deg); }
    .lb-nav{ top: 50%; transform: translateY(-50%); }
    .lb-nav.lb-prev{ right: 24px; }   /* RTL: السابق على اليمين */
    .lb-nav.lb-next{ left: 24px; }
    .lb-nav:hover{ background: rgba(255,255,255,.28); transform: translateY(-50%) scale(1.08); }
    .lb-nav[hidden]{ display:none; }
    .lb-counter{
        position:absolute; top: 24px; right: 50%; transform: translateX(50%);
        color:#fff; font-weight:700; font-size:.9rem;
        background: rgba(255,255,255,.14);
        border:1px solid rgba(255,255,255,.18);
        padding: 6px 14px; border-radius: 999px;
        backdrop-filter: blur(8px);
    }

    /* ========== Bottom CTA back ========== */
    .dx-bottom{
        margin-top: 2.5rem; display:flex; justify-content:center;
    }
    .dx-bottom .btn-file{
        padding: 13px 32px; font-size: 1rem;
        background: var(--dx-grad-accent);
        background-size: 180% 180%; background-position: 0% 50%;
        box-shadow: 0 14px 28px -10px rgba(255,95,3,.5);
        transition: background-position .6s ease, transform .35s var(--dx-ease), box-shadow .35s ease;
    }
    .dx-bottom .btn-file:hover{ background-position: 100% 50%; transform: translateY(-3px); }

    /* ========== Responsive ========== */
    @@media (max-width: 768px) {
        .details-hero-enterprise{ padding: 3rem 0 2.5rem; border-radius: 0; }
        .hero-title{ font-size: 1.55rem; }
        .block-body{ padding: 1.25rem; }
        .file-card{ flex-direction: column; align-items: flex-start; }
        .file-card .btn-group{ width: 100%; display:flex; gap:8px; }
        .file-card > div:last-child{ width: 100%; display:flex; gap:8px; }
        .btn-file{ width: 100%; justify-content: center; }
        .lb-nav.lb-prev{ right: 10px; }
        .lb-nav.lb-next{ left: 10px; }
    }

    /* ========== Reduced motion ========== */
    @@media (prefers-reduced-motion: reduce){
        .dx-reveal,.dx-reveal-zoom{ opacity:1 !important; animation:none !important; }
        .details-hero-enterprise::before,.details-hero-enterprise::after,
        .hero-title,.badge-pill.dx-pulse{ animation:none !important; }
        *{ transition:none !important; }
    }
</style>

<!-- شريط تقدّم القراءة -->
<div class="dx-progress" id="dxProgress" aria-hidden="true"></div>

<!-- ═══════════════════════════════════════
     HERO
═══════════════════════════════════════ -->
<section class="details-hero-enterprise">
    <div class="dx-hero-grid" aria-hidden="true"></div>

    <div class="container position-relative" style="z-index:2;">
        <a asp-area="Student" asp-controller="News" asp-action="Index" class="back-link dx-reveal-zoom dx-in">
            <i class="fas fa-arrow-right"></i> العودة للأخبار
        </a>

        <div class="dx-reveal dx-d1 dx-in">
            <div class="hero-badges">
                <span class="badge-pill dx-pulse" style="background:rgba(255,95,3,.18); color:#FFD2B0; border-color:rgba(255,95,3,.35);">
                    <i class="fas fa-bullhorn"></i> منشور
                </span>
                <span class="badge-pill">
                    <i class="fas fa-calendar-alt"></i>
                    @Model.CreatedAt.ToString("yyyy/MM/dd")
                </span>
                @if (Model.UpdatedAt.HasValue)
                {
                    <span class="badge-pill" style="background:rgba(255,255,255,.08); color:rgba(255,255,255,.78); border-color:rgba(255,255,255,.12);">
                        <i class="fas fa-edit"></i>
                        تم التعديل: @Model.UpdatedAt.Value.ToString("yyyy/MM/dd")
                    </span>
                }
                @if (Model.Attachments.Any())
                {
                    <span class="badge-pill" style="background:rgba(16,185,129,.20); color:#6EE7B7; border-color:rgba(16,185,129,.35);">
                        <i class="fas fa-paperclip"></i> @Model.Attachments.Count مرفق
                    </span>
                }
            </div>
            <h1 class="hero-title">@Model.Title</h1>

            <div class="dx-hero-meta">
                <span><i class="far fa-clock"></i> @Model.CreatedAt.ToString("HH:mm")</span>
                @if (images.Any())
                {
                    <span><i class="far fa-images"></i> @images.Count صورة</span>
                }
                @if (videos.Any())
                {
                    <span><i class="fas fa-video"></i> @videos.Count فيديو</span>
                }
                @if (pdfs.Any())
                {
                    <span><i class="fas fa-file-pdf"></i> @pdfs.Count PDF</span>
                }
            </div>
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════
     MAIN CONTENT
═══════════════════════════════════════ -->
<main class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">

            <!-- Gallery -->
            @if (images.Any())
            {
                <div class="content-block-enterprise dx-reveal dx-d1">
                    @if (images.Count == 1)
                    {
                        <div class="gallery-grid single p-3">
                            <div class="gallery-item featured" data-dx-lightbox data-src="@images[0].FilePath">
                                <img src="@images[0].FilePath" alt="@Model.Title" loading="lazy" />
                                <div class="zoom-btn"><i class="fas fa-expand"></i></div>
                            </div>
                        </div>
                    }
                    else if (images.Count == 2)
                    {
                        <div class="gallery-grid double p-3">
                            @foreach (var img in images)
                            {
                                <div class="gallery-item" data-dx-lightbox data-src="@img.FilePath">
                                    <img src="@img.FilePath" alt="" loading="lazy" />
                                    <div class="zoom-btn"><i class="fas fa-expand"></i></div>
                                </div>
                            }
                        </div>
                    }
                    else if (images.Count == 3)
                    {
                        <div class="p-3">
                            <div class="gallery-item featured mb-3" data-dx-lightbox data-src="@images[0].FilePath">
                                <img src="@images[0].FilePath" alt="" loading="lazy" />
                                <div class="zoom-btn"><i class="fas fa-expand"></i></div>
                            </div>
                            <div class="gallery-grid double">
                                @for (int i = 1; i < 3; i++)
                                {
                                    <div class="gallery-item" data-dx-lightbox data-src="@images[i].FilePath">
                                        <img src="@images[i].FilePath" alt="" loading="lazy" />
                                        <div class="zoom-btn"><i class="fas fa-expand"></i></div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="p-3">
                            <div class="gallery-item featured mb-3" data-dx-lightbox data-src="@images[0].FilePath">
                                <img src="@images[0].FilePath" alt="" loading="lazy" />
                                <div class="zoom-btn"><i class="fas fa-expand"></i></div>
                            </div>
                            <div class="gallery-grid multi">
                                @for (int i = 1; i < Math.Min(images.Count, 5); i++)
                                {
                                    var showMore = i == 4 && images.Count > 5;
                                    <div class="gallery-item @(showMore ? "has-more" : "")"
                                         data-dx-lightbox data-src="@images[i].FilePath">
                                        <img src="@images[i].FilePath" alt="" loading="lazy" style="@(showMore ? "filter:brightness(0.5)" : "")" />
                                        @if (showMore)
                                        {
                                            <div class="gallery-overlay">+@(images.Count - 4)</div>
                                        }
                                        <div class="zoom-btn"><i class="fas fa-expand"></i></div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }

            <!-- Content -->
            <div class="content-block-enterprise dx-reveal dx-d2">
                <div class="block-header">
                    <div class="header-icon" style="background:var(--dx-grad-primary);">
                        <i class="fas fa-align-right"></i>
                    </div>
                    <span class="header-title">تفاصيل المنشور</span>
                </div>
                <div class="block-body">
                    <article class="post-content" id="dxArticle">@Model.Content</article>
                </div>
            </div>

            <!-- Videos -->
            @if (videos.Any())
            {
                <div class="content-block-enterprise dx-reveal dx-d2">
                    <div class="block-header">
                        <div class="header-icon" style="background:linear-gradient(135deg, #8B5CF6, #6D28D9);">
                            <i class="fas fa-video"></i>
                        </div>
                        <span class="header-title">فيديوهات مرفقة</span>
                        <span class="header-count">@videos.Count</span>
                    </div>
                    <div class="block-body">
                        <div class="row g-3">
                            @foreach (var video in videos)
                            {
                                <div class="col-md-6">
                                    <video controls preload="metadata" class="dx-video">
                                        <source src="@video.FilePath" />
                                        متصفحك لا يدعم تشغيل الفيديو.
                                    </video>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- PDFs -->
            @if (pdfs.Any())
            {
                <div class="content-block-enterprise dx-reveal dx-d3">
                    <div class="block-header" style="background: linear-gradient(135deg, #FEF2F2, #fff);">
                        <div class="header-icon" style="background:linear-gradient(135deg, #EF4444, #DC2626);">
                            <i class="fas fa-file-pdf"></i>
                        </div>
                        <span class="header-title" style="color:#B91C1C;">ملفات PDF</span>
                        <span class="header-count">@pdfs.Count</span>
                    </div>
                    <div class="block-body">
                        @foreach (var pdf in pdfs)
                        {
                            <div class="file-card">
                                <div class="file-info">
                                    <div class="file-icon" style="background:linear-gradient(135deg, #EF4444, #DC2626);">
                                        <i class="fas fa-file-pdf"></i>
                                    </div>
                                    <div>
                                        <p class="file-name">@pdf.FileName</p>
                                        <span class="file-type">ملف PDF</span>
                                    </div>
                                </div>
                                <div class="d-flex gap-2 flex-wrap">
                                    <a href="@pdf.FilePath" target="_blank" rel="noopener noreferrer" class="btn-file primary">
                                        <i class="fas fa-eye"></i> عرض
                                    </a>
                                    <a href="@pdf.FilePath" download="@pdf.FileName" class="btn-file secondary">
                                        <i class="fas fa-download"></i> تحميل
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Files -->
            @if (files.Any())
            {
                <div class="content-block-enterprise dx-reveal dx-d3">
                    <div class="block-header" style="background: linear-gradient(135deg, #F5F3FF, #fff);">
                        <div class="header-icon" style="background:var(--dx-grad-primary);">
                            <i class="fas fa-paperclip"></i>
                        </div>
                        <span class="header-title">مرفقات أخرى</span>
                        <span class="header-count">@files.Count</span>
                    </div>
                    <div class="block-body">
                        @foreach (var file in files)
                        {
                            <div class="file-card">
                                <div class="file-info">
                                    <div class="file-icon" style="background:var(--dx-grad-primary);">
                                        <i class="fas fa-file"></i>
                                    </div>
                                    <div>
                                        <p class="file-name">@file.FileName</p>
                                        <span class="file-type">ملف مرفق</span>
                                    </div>
                                </div>
                                <a href="@file.FilePath" download="@file.FileName" class="btn-file primary">
                                    <i class="fas fa-download"></i> تحميل
                                </a>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Embeds -->
            @if (embeds.Any())
            {
                <div class="content-block-enterprise dx-reveal dx-d3">
                    <div class="block-header" style="background: linear-gradient(135deg, #FFFBEB, #fff);">
                        <div class="header-icon" style="background:linear-gradient(135deg, #F59E0B, #D97706);">
                            <i class="fas fa-link"></i>
                        </div>
                        <span class="header-title" style="color:#B45309;">محتوى مضمّن</span>
                        <span class="header-count">@embeds.Count</span>
                    </div>
                    <div class="block-body">
                        @foreach (var embed in embeds)
                        {
                            <div class="embed-wrapper">
                                <iframe src="@embed.EmbedUrl"
                                        loading="lazy"
                                        allowfullscreen
                                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; fullscreen"
                                        referrerpolicy="strict-origin-when-cross-origin"></iframe>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Bottom Navigation -->
            <div class="dx-bottom dx-reveal dx-d3">
                <a asp-area="Student" asp-controller="News" asp-action="Index" class="btn-file primary">
                    <i class="fas fa-arrow-right"></i> العودة لجميع الأخبار
                </a>
            </div>

        </div>
    </div>
</main>

<!-- ═══════════════════════════════════════
     LIGHTBOX (محسّن)
═══════════════════════════════════════ -->
<div class="lightbox-enterprise" id="enterpriseLightbox" role="dialog" aria-modal="true" aria-label="عارض الصور">
    <button class="lb-close" type="button" aria-label="إغلاق" data-dx-lb-close>
        <i class="fas fa-times"></i>
    </button>
    <span class="lb-counter" id="dxLbCounter" aria-live="polite">1 / 1</span>
    <button class="lb-nav lb-prev" type="button" aria-label="السابق" data-dx-lb-prev>
        <i class="fas fa-chevron-right"></i>
    </button>
    <img id="lightboxImage" src="" alt="صورة مكبرة" />
    <button class="lb-nav lb-next" type="button" aria-label="التالي" data-dx-lb-next>
        <i class="fas fa-chevron-left"></i>
    </button>
</div>

@*
    ═══════════════════════════════════════════════════════════════
      Vanilla JS — لا يستخدم innerHTML على بيانات السيرفر، ولا eval.
      • IntersectionObserver لظهور البلوكات.
      • شريط تقدّم قراءة المحتوى.
      • Lightbox مع تنقّل بالأسهم/المفاتيح/سحب.
      • يحترم prefers-reduced-motion.
    ═══════════════════════════════════════════════════════════════
*@
@section Scripts {
    <script>
        (function () {
            'use strict';

            var prefersReduced = window.matchMedia &&
                window.matchMedia('(prefers-reduced-motion: reduce)').matches;

            // 1) Reveal on scroll
            var revealEls = document.querySelectorAll('.dx-reveal, .dx-reveal-zoom');
            if (prefersReduced || !('IntersectionObserver' in window)) {
                revealEls.forEach(function (el) { el.classList.add('dx-in'); });
            } else {
                var io = new IntersectionObserver(function (entries) {
                    entries.forEach(function (entry) {
                        if (entry.isIntersecting) {
                            entry.target.classList.add('dx-in');
                            io.unobserve(entry.target);
                        }
                    });
                }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
                revealEls.forEach(function (el) { io.observe(el); });
            }

            // 2) Reading progress bar
            var bar = document.getElementById('dxProgress');
            var article = document.getElementById('dxArticle');
            function updateProgress() {
                if (!bar) return;
                var doc = document.documentElement;
                var max = (doc.scrollHeight - doc.clientHeight) || 1;
                var pct = Math.min(100, Math.max(0, (window.scrollY / max) * 100));
                bar.style.width = pct + '%';
            }
            window.addEventListener('scroll', updateProgress, { passive: true });
            window.addEventListener('resize', updateProgress);
            updateProgress();

            // 3) Lightbox مع تنقّل
            var lightbox    = document.getElementById('enterpriseLightbox');
            var lightboxImg = document.getElementById('lightboxImage');
            var counter     = document.getElementById('dxLbCounter');
            var btnClose    = document.querySelector('[data-dx-lb-close]');
            var btnPrev     = document.querySelector('[data-dx-lb-prev]');
            var btnNext     = document.querySelector('[data-dx-lb-next]');
            var triggers    = Array.prototype.slice.call(document.querySelectorAll('[data-dx-lightbox]'));
            // اجمع كل المصادر بترتيب ظهورها
            var sources = triggers.map(function (el) { return el.getAttribute('data-src'); }).filter(Boolean);
            var current = 0;

            function showAt(index) {
                if (!sources.length) return;
                if (index < 0) index = sources.length - 1;
                if (index >= sources.length) index = 0;
                current = index;
                // .src آمن: المتصفح لا يفسر القيمة كـ HTML.
                lightboxImg.src = sources[current];
                lightboxImg.alt = 'صورة ' + (current + 1);
                if (counter) counter.textContent = (current + 1) + ' / ' + sources.length;
                // إظهار/إخفاء أزرار التنقل لو في صورة واحدة فقط
                var single = sources.length <= 1;
                if (btnPrev) btnPrev.hidden = single;
                if (btnNext) btnNext.hidden = single;
            }
            function openLb(index) {
                showAt(index);
                lightbox.classList.add('active');
                document.body.style.overflow = 'hidden';
            }
            function closeLb() {
                lightbox.classList.remove('active');
                document.body.style.overflow = '';
                setTimeout(function () { lightboxImg.src = ''; }, 300);
            }

            triggers.forEach(function (el, idx) {
                el.addEventListener('click', function () { openLb(idx); });
                el.setAttribute('role', 'button');
                el.setAttribute('tabindex', '0');
                el.addEventListener('keydown', function (e) {
                    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openLb(idx); }
                });
            });

            if (btnClose) btnClose.addEventListener('click', function (e) { e.stopPropagation(); closeLb(); });
            if (btnPrev)  btnPrev.addEventListener('click',  function (e) { e.stopPropagation(); showAt(current - 1); });
            if (btnNext)  btnNext.addEventListener('click',  function (e) { e.stopPropagation(); showAt(current + 1); });

            // إغلاق بالضغط على الخلفية فقط (مش على الصورة أو الأزرار)
            lightbox.addEventListener('click', function (e) {
                if (e.target === lightbox) closeLb();
            });

            // اختصارات لوحة المفاتيح
            document.addEventListener('keydown', function (e) {
                if (!lightbox.classList.contains('active')) return;
                if (e.key === 'Escape')      closeLb();
                else if (e.key === 'ArrowLeft')  showAt(current + 1); // RTL: يسار = التالي
                else if (e.key === 'ArrowRight') showAt(current - 1); // RTL: يمين = السابق
            });

            // سحب باللمس على الموبايل
            var touchStartX = null;
            lightbox.addEventListener('touchstart', function (e) {
                if (e.touches && e.touches.length === 1) touchStartX = e.touches[0].clientX;
            }, { passive: true });
            lightbox.addEventListener('touchend', function (e) {
                if (touchStartX === null) return;
                var dx = (e.changedTouches[0].clientX - touchStartX);
                if (Math.abs(dx) > 50) {
                    if (dx < 0) showAt(current - 1); // سحب يسار → السابق (RTL)
                    else        showAt(current + 1); // سحب يمين → التالي (RTL)
                }
                touchStartX = null;
            });
        })();
    </script>
}
