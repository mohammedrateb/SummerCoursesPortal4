    @*
        ═══════════════════════════════════════════════════════════════
          Vanilla JS — لا يستخدم eval ولا innerHTML على بيانات خارجية.
          • Sticky scroll shadow على الـ navbar.
          • Active link auto-detect حسب الـ URL الحالي.
          • Fallback toggle لو Bootstrap collapse مش متاح.
          • قفل القائمة عند الضغط خارجها أو على Esc.
          • Back-to-top button مع scroll smooth.
          • يحترم prefers-reduced-motion.
        ═══════════════════════════════════════════════════════════════
    *@
    <script>
        (function () {
            'use strict';

            var navbar = document.querySelector('.navbar-enterprise');
            var totop  = document.querySelector('.lyt-totop');

            var prefersReduced = window.matchMedia &&
                window.matchMedia('(prefers-reduced-motion: reduce)').matches;

            // ===== NAVBAR =====
            if (navbar){
                var toggle   = navbar.querySelector('.mobile-toggle');
                var collapse = navbar.querySelector('#navMenu');
                var links    = navbar.querySelectorAll('.nav-enterprise-link');

                // 1) Scrolled state على navbar + Back-to-top visibility
                function onScroll(){
                    var y = window.scrollY || window.pageYOffset || 0;
                    if (y > 8) navbar.classList.add('nv-scrolled');
                    else navbar.classList.remove('nv-scrolled');
                    if (totop){
                        if (y > 320) totop.classList.add('is-visible');
                        else totop.classList.remove('is-visible');
                    }
                }
                window.addEventListener('scroll', onScroll, { passive: true });
                onScroll();

                // 2) Active link auto-detect (مقارنة آمنة بالـ pathname)
                try {
                    var currentPath = (window.location.pathname || '').toLowerCase().replace(/\/+$/, '');
                    links.forEach(function (a) {
                        var hrefAttr = a.getAttribute('href') || '';
                        if (!hrefAttr || hrefAttr === '#') return;
                        var linkPath = '';
                        try {
                            linkPath = new URL(a.href, window.location.origin).pathname.toLowerCase().replace(/\/+$/, '');
                        } catch (e) { return; }
                        if (linkPath && linkPath === currentPath) {
                            a.classList.add('active');
                            a.setAttribute('aria-current', 'page');
                        }
                    });
                } catch (e) { /* تجاهل بأمان */ }

                // 3) Fallback toggle (لو Bootstrap collapse مش متاح)
                var hasBootstrap = !!(window.bootstrap && window.bootstrap.Collapse);

                function setOpen(open){
                    if (!collapse || !toggle) return;
                    if (open){
                        collapse.classList.add('nv-open');
                        toggle.setAttribute('aria-expanded', 'true');
                        toggle.setAttribute('aria-label', 'إغلاق القائمة');
                    } else {
                        collapse.classList.remove('nv-open');
                        toggle.setAttribute('aria-expanded', 'false');
                        toggle.setAttribute('aria-label', 'فتح القائمة');
                    }
                }

                if (!hasBootstrap && toggle && collapse){
                    toggle.removeAttribute('data-bs-toggle');
                    toggle.removeAttribute('data-bs-target');
                    toggle.addEventListener('click', function (e) {
                        e.preventDefault();
                        setOpen(!collapse.classList.contains('nv-open'));
                    });
                }

                // 4) قفل القائمة عند اختيار رابط (موبايل)
                links.forEach(function (a) {
                    a.addEventListener('click', function () {
                        if (window.matchMedia('(max-width: 991.98px)').matches){
                            if (hasBootstrap){
                                try {
                                    var inst = window.bootstrap.Collapse.getOrCreateInstance(collapse, { toggle: false });
                                    inst.hide();
                                } catch (e) { setOpen(false); }
                            } else {
                                setOpen(false);
                            }
                        }
                    });
                });

                // 5) قفل عند الضغط خارج القائمة
                document.addEventListener('click', function (e) {
                    if (!window.matchMedia('(max-width: 991.98px)').matches) return;
                    if (!collapse || !toggle) return;
                    var isOpen = collapse.classList.contains('show') || collapse.classList.contains('nv-open');
                    if (!isOpen) return;
                    if (collapse.contains(e.target) || toggle.contains(e.target)) return;
                    if (hasBootstrap){
                        try {
                            var inst = window.bootstrap.Collapse.getOrCreateInstance(collapse, { toggle: false });
                            inst.hide();
                        } catch (err) { setOpen(false); }
                    } else {
                        setOpen(false);
                    }
                });

                // 6) قفل بزر Escape
                document.addEventListener('keydown', function (e) {
                    if (e.key !== 'Escape') return;
                    if (!collapse) return;
                    if (collapse.classList.contains('show') || collapse.classList.contains('nv-open')){
                        if (hasBootstrap){
                            try {
                                var inst = window.bootstrap.Collapse.getOrCreateInstance(collapse, { toggle: false });
                                inst.hide();
                            } catch (err) { setOpen(false); }
                        } else {
                            setOpen(false);
                        }
                        if (toggle) toggle.focus();
                    }
                });

                // 7) مزامنة aria-expanded مع أحداث Bootstrap collapse
                if (collapse){
                    collapse.addEventListener('shown.bs.collapse', function () {
                        if (toggle){
                            toggle.setAttribute('aria-expanded', 'true');
                            toggle.setAttribute('aria-label', 'إغلاق القائمة');
                        }
                    });
                    collapse.addEventListener('hidden.bs.collapse', function () {
                        if (toggle){
                            toggle.setAttribute('aria-expanded', 'false');
                            toggle.setAttribute('aria-label', 'فتح القائمة');
                        }
                    });
                }

                // 8) لو حصل resize للديسكتوب وكانت القائمة مفتوحة على الموبايل، نقفلها
                var mq = window.matchMedia('(min-width: 992px)');
                function onMqChange(ev){
                    if (ev.matches){
                        if (hasBootstrap && collapse){
                            try {
                                var inst = window.bootstrap.Collapse.getOrCreateInstance(collapse, { toggle: false });
                                inst.hide();
                            } catch (e) { /* تجاهل */ }
                        }
                        setOpen(false);
                    }
                }
                if (mq.addEventListener) mq.addEventListener('change', onMqChange);
                else if (mq.addListener) mq.addListener(onMqChange);
            }

            // ===== Back to top =====
            if (totop){
                totop.addEventListener('click', function () {
                    try {
                        window.scrollTo({ top: 0, behavior: prefersReduced ? 'auto' : 'smooth' });
                    } catch (e) {
                        window.scrollTo(0, 0);
                    }
                });
            }
        })();
    </script>

    @RenderSection("Scripts", required: false)
</body>
