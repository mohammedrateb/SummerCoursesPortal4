@*
    ═══════════════════════════════════════════════════════════════
      Register/Index.cshtml — نسخة محسّنة بالكامل
      • Glassmorphism + Aurora header + animations.
      • FA6 Free icons فقط.
      • Class prefix: rg-* (Register).
      • شريط تقدّم خطوات (steps progress) مرئي.
      • Auto-format للرقم القومي والموبايل (يقبل أرقام عربية).
      • زر submit بحالة loading + منع double-submit.
      • السكربت الجديد لإظهار/إخفاء المواد آمن وبدون أخطاء console.
      • Anti-forgery + asp-* helpers محفوظة. صفر تعديل Backend.
      • يحترم prefers-reduced-motion.
    ═══════════════════════════════════════════════════════════════
*@
@model WebApplication1.ViewModels.Student.StudentRegisterViewModel
@{
    ViewData["Title"] = "تسجيل بيانات جديدة";
}

<style>
    .rg-scope{
        --rg-primary:#072C2C; --rg-primary-2:#1e6b6b;
        --rg-secondary:#FF5F03; --rg-secondary-2:#ffb060;
        --rg-success:#16A34A; --rg-warning:#D97706; --rg-error:#DC2626;
        --rg-text:#111827; --rg-muted:#6B7280; --rg-border:#D1D5DB;
        --rg-surface:#fff; --rg-surface-alt:#f8fafc;
        --rg-glass-bg: rgba(255,255,255,.78);
        --rg-glass-border: rgba(255,255,255,.65);
        --rg-shadow:0 10px 30px -16px rgba(7,44,44,.25);
        --rg-shadow-lg:0 24px 60px -22px rgba(7,44,44,.35);
        --rg-radius:14px; --rg-radius-lg:20px;
        --rg-ease: cubic-bezier(.22,.61,.36,1);
        --rg-bounce: cubic-bezier(.34,1.56,.64,1);
        --rg-grad-primary: linear-gradient(135deg,#072C2C 0%,#1e6b6b 100%);
        --rg-grad-accent:  linear-gradient(135deg,#FF5F03 0%,#ffb060 100%);
        --rg-grad-success: linear-gradient(135deg,#16A34A 0%,#22c55e 100%);
        --rg-grad-warning: linear-gradient(135deg,#D97706 0%,#f59e0b 100%);
        --rg-grad-mix:     linear-gradient(120deg,#072C2C,#1e6b6b 40%,#FF5F03);
    }

    @@keyframes rg-up   { from{opacity:0;transform:translateY(15px)} to{opacity:1;transform:translateY(0)} }
    @@keyframes rg-fade { from{opacity:0} to{opacity:1} }
    @@keyframes rg-shine{ 0%{transform:translateX(-100%)} 60%{transform:translateX(100%)} 100%{transform:translateX(100%)} }
    @@keyframes rg-shake{ 0%,100%{transform:translateX(0)} 20%,60%{transform:translateX(-6px)} 40%,80%{transform:translateX(6px)} }

    .rg-anim { animation: rg-up .55s var(--rg-ease) both; }
    .rg-fade { animation: rg-fade .6s var(--rg-ease) both; }
    .rg-d1{animation-delay:.10s} .rg-d2{animation-delay:.20s} .rg-d3{animation-delay:.30s}

    /* ========== Header ========== */
    .rg-header{
        position:relative; isolation:isolate; overflow:hidden;
        padding: 3rem 1rem 3.5rem;
        margin-bottom: 2rem;
        color:#fff; text-align:center;
        background:
          radial-gradient(60% 80% at 80% 0%, rgba(255,95,3,.22), transparent 60%),
          radial-gradient(60% 80% at 10% 100%, rgba(30,107,107,.30), transparent 60%),
          linear-gradient(160deg, #051d1d 0%, #072C2C 60%, #0a3a3a 100%);
        border-bottom: 4px solid var(--rg-secondary);
    }
    .rg-header::before{
        content:""; position:absolute; inset:0; pointer-events:none; z-index:-1;
        background-image:
          linear-gradient(rgba(255,255,255,.05) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,.05) 1px, transparent 1px);
        background-size: 44px 44px;
        mask-image: radial-gradient(ellipse at 50% 50%, #000 30%, transparent 75%);
        -webkit-mask-image: radial-gradient(ellipse at 50% 50%, #000 30%, transparent 75%);
    }
    .rg-header::after{
        content:""; position:absolute; left:0; right:0; bottom:-1px; height:50px;
        background: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1440 60' preserveAspectRatio='none'><path fill='%23f8fafc' d='M0,30 C240,60 480,0 720,30 C960,60 1200,0 1440,30 L1440,60 L0,60 Z'/></svg>") no-repeat top center / cover;
        pointer-events:none;
    }
    .rg-header-icon{
        width:78px; height:78px;
        background: var(--rg-grad-accent);
        border-radius: 20px;
        display:inline-flex; align-items:center; justify-content:center;
        font-size: 30px; color:#fff;
        margin-bottom: 1rem;
        box-shadow: 0 14px 30px -8px rgba(255,95,3,.55);
        position:relative; overflow:hidden;
    }
    .rg-header-icon::after{
        content:""; position:absolute; inset:0;
        background: linear-gradient(120deg, transparent 30%, rgba(255,255,255,.5) 50%, transparent 70%);
        transform: translateX(-100%);
        animation: rg-shine 3.2s ease-in-out infinite;
    }
    .rg-header-title{
        font-family:'Oswald',sans-serif;
        font-size: clamp(1.6rem, 2.4vw, 2.1rem);
        font-weight:700; margin:0 0 .5rem; color:#fff; letter-spacing:.3px;
    }
    .rg-header-sub{ font-size:1rem; color:rgba(255,255,255,.85); margin:0; font-weight:500; }

    /* ========== Steps Progress (visual) ========== */
    .rg-steps{
        display:flex; justify-content:center; gap: 8px;
        margin: -1.25rem auto 1.5rem; max-width: 520px;
        position: relative; z-index: 2; padding: 0 1rem;
    }
    .rg-step-pill{
        flex:1; height: 6px; border-radius: 50px;
        background: rgba(255,255,255,.4);
        overflow:hidden; position:relative;
        box-shadow: 0 2px 6px rgba(0,0,0,.2);
    }
    .rg-step-pill::after{
        content:""; position:absolute; inset:0;
        background: var(--rg-grad-accent);
        transform: translateX(-100%);
        transition: transform .6s var(--rg-ease);
    }
    .rg-step-pill.is-active::after{ transform: translateX(0); }

    /* ========== Card (Glass) ========== */
    .rg-card{
        position:relative;
        background: var(--rg-glass-bg);
        backdrop-filter: blur(14px) saturate(150%);
        -webkit-backdrop-filter: blur(14px) saturate(150%);
        border-radius: var(--rg-radius-lg);
        box-shadow: var(--rg-shadow-lg);
        border: 1px solid var(--rg-glass-border);
        padding: 2.5rem; overflow: hidden;
    }
    .rg-card::before{
        content:""; position:absolute; left:0; right:0; top:0; height:4px;
        background: var(--rg-grad-mix); opacity:.85;
    }
    @@media (max-width: 992px){ .rg-card{ padding: 2rem; } }
    @@media (max-width: 576px){ .rg-card{ padding: 1.4rem; } }

    /* ========== Step Header ========== */
    .rg-step-h{
        display:flex; align-items:center; gap: 14px;
        margin-bottom: 1.25rem;
    }
    .rg-step-num{
        width: 44px; height: 44px;
        border-radius: 14px;
        display:inline-flex; align-items:center; justify-content:center;
        color:#fff; font-weight:800; font-family:'Oswald',sans-serif;
        font-size: 1.15rem;
        flex-shrink: 0;
        box-shadow: 0 8px 18px -8px rgba(7,44,44,.5);
        position: relative; overflow: hidden;
    }
    .rg-step-num::after{
        content:""; position:absolute; inset:0;
        background: linear-gradient(120deg, transparent 30%, rgba(255,255,255,.4) 50%, transparent 70%);
        transform: translateX(-100%);
    }
    .rg-card:hover .rg-step-num::after{ animation: rg-shine 1.5s ease-in-out; }
    .rg-step-num-1{ background: var(--rg-grad-primary); }
    .rg-step-num-2{ background: var(--rg-grad-accent); }
    .rg-step-num-3{ background: var(--rg-grad-success); }
    .rg-step-title{
        font-family:'Oswald',sans-serif;
        font-size: 1.2rem; font-weight: 700;
        margin: 0; color: var(--rg-primary);
    }
    .rg-step-sub{ font-size:.85rem; color: var(--rg-muted); display:block; margin-top:2px; }

    /* ========== Form ========== */
    .rg-label{
        display:flex; align-items:center; gap:8px;
        font-weight:700; font-size:.95rem; color: var(--rg-text);
        margin-bottom: .5rem;
    }
    .rg-label i{
        color: var(--rg-primary); font-size:.9rem;
        width:18px; text-align:center;
    }
    .rg-input, .rg-select{
        width:100%;
        padding: .8rem 1.05rem;
        font-family:'Ubuntu',sans-serif;
        font-size: 1rem;
        color: var(--rg-text);
        background: var(--rg-surface-alt);
        border: 2px solid var(--rg-border);
        border-radius: var(--rg-radius);
        transition: border-color .25s ease, background .25s ease, box-shadow .25s ease, transform .25s ease;
    }
    .rg-input::placeholder{ color: var(--rg-muted); }
    .rg-input:focus, .rg-select:focus{
        outline:none;
        border-color: var(--rg-secondary);
        background:#fff;
        box-shadow: 0 0 0 4px rgba(255,95,3,.15);
        transform: translateY(-1px);
    }
    .rg-input.is-invalid{ border-color: var(--rg-error); }
    .rg-input.is-valid{ border-color: var(--rg-success); }
    .rg-help{
        font-size:.78rem; color: var(--rg-muted); margin-top:.3rem;
        display:flex; align-items:center; gap:6px;
        font-variant-numeric: tabular-nums;
    }
    .rg-help.is-ok{ color: var(--rg-success); }

    /* ========== Divider ========== */
    .rg-divider{
        position:relative; border:0; height:1px;
        background: linear-gradient(90deg, transparent, rgba(7,44,44,.18), transparent);
        margin: 2rem 0;
    }
    .rg-divider::after{
        content: "\f0c8"; font-family:"Font Awesome 6 Free"; font-weight:900;
        position:absolute; left:50%; top:50%;
        transform: translate(-50%, -50%) rotate(45deg);
        background: var(--rg-surface);
        color: var(--rg-secondary);
        padding: 0 10px;
        font-size:.75rem;
    }

    /* ========== Subjects ========== */
    .rg-subjects{ display:flex; flex-direction:column; gap: .9rem; }
    .rg-subject-box{
        animation: rg-up .35s var(--rg-ease);
    }
    .rg-subject-box[hidden]{ display:none !important; }
    .rg-label .rg-icon-sub{
        width:24px; height:24px; border-radius:8px;
        display:inline-flex; align-items:center; justify-content:center;
        color:#fff; font-size:.7rem;
    }
    .rg-icon-1{ background: var(--rg-grad-primary); }
    .rg-icon-2{ background: var(--rg-grad-warning); }
    .rg-icon-3{ background: linear-gradient(135deg, var(--rg-error), #b91c1c); }
    .rg-icon-4{ background: linear-gradient(135deg, #6D28D9, #4c1d95); }
    .rg-icon-5{ background: linear-gradient(135deg, #0EA5E9, #0369a1); }

    /* ========== Alert ========== */
    .rg-alert{
        display:flex; align-items:flex-start; gap:10px;
        padding: 1rem 1.15rem;
        border-radius: var(--rg-radius);
        background:#FEF2F2; border:1px solid #FECACA; color: var(--rg-error);
        font-size:.95rem; font-weight:600; margin-bottom: 1.5rem;
        animation: rg-up .35s var(--rg-ease), rg-shake .5s ease .35s;
    }
    .rg-alert i{ font-size:1.15rem; flex-shrink:0; margin-top:2px; }
    .rg-alert ul{ margin:0; padding-right: 1.2rem; }
    .rg-alert li{ margin: 2px 0; }

    /* ========== Submit ========== */
    .rg-actions{
        text-align:center; margin-top: 2.25rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(7,44,44,.10);
    }
    .rg-btn{
        background: var(--rg-grad-accent);
        color:#fff; border:none;
        border-radius: 50px;
        font-family:'Ubuntu',sans-serif;
        font-weight:700; font-size:1.05rem;
        padding: .95rem 2.5rem;
        cursor:pointer;
        display:inline-flex; align-items:center; gap:10px;
        box-shadow: 0 10px 22px -10px rgba(255,95,3,.55);
        position:relative; overflow:hidden; isolation:isolate;
        transition: transform .3s var(--rg-ease), box-shadow .3s ease, opacity .25s ease;
    }
    .rg-btn::after{
        content:""; position:absolute; inset:0;
        background: linear-gradient(120deg, transparent 30%, rgba(255,255,255,.35) 50%, transparent 70%);
        transform: translateX(-100%); transition: transform .8s ease;
    }
    .rg-btn:hover{ transform: translateY(-3px); box-shadow: 0 16px 30px -10px rgba(255,95,3,.7); color:#fff; }
    .rg-btn:hover::after{ transform: translateX(100%); }
    .rg-btn:disabled{ opacity:.7; cursor: not-allowed; transform:none; }
    .rg-spinner{ display:none; width:18px; height:18px; border:2.5px solid rgba(255,255,255,.4); border-top-color:#fff; border-radius:50%; animation: rg-spin 0.7s linear infinite; }
    .rg-btn.is-loading .rg-spinner{ display:inline-block; }
    .rg-btn.is-loading .rg-btn-icon{ display:none; }
    @@keyframes rg-spin { to { transform: rotate(360deg); } }

    /* ========== Accessibility ========== */
    .rg-input:focus-visible, .rg-select:focus-visible, .rg-btn:focus-visible{
        outline: 2px solid var(--rg-secondary); outline-offset: 3px;
    }
    @@media (prefers-reduced-motion: reduce){
        .rg-scope *, .rg-scope *::before, .rg-scope *::after{
            animation: none !important; transition: none !important;
        }
    }
</style>

<div class="rg-scope">

    <section class="rg-header rg-fade">
        <div class="container">
            <div class="rg-header-icon" aria-hidden="true">
                <i class="fas fa-user-plus"></i>
            </div>
            <h1 class="rg-header-title">تسجيل بيانات جديدة</h1>
            <p class="rg-header-sub">أدخل بياناتك بدقة لإتمام التسجيل بنجاح</p>
        </div>
    </section>

    <div class="rg-steps" aria-hidden="true">
        <div class="rg-step-pill is-active"></div>
        <div class="rg-step-pill is-active"></div>
        <div class="rg-step-pill is-active"></div>
    </div>

    <div class="container pb-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="rg-alert" role="alert">
                        <i class="fas fa-circle-exclamation" aria-hidden="true"></i>
                        <div>
                            <strong>برجاء تصحيح الأخطاء التالية:</strong>
                            @Html.ValidationSummary(false, "", new { @class = "mb-0" })
                        </div>
                    </div>
                }

                <div class="rg-card rg-anim rg-d1">
                    <form asp-area="Student" asp-controller="Register" asp-action="Index"
                          method="post" id="rg-form" novalidate>
                        @Html.AntiForgeryToken()

                        <!-- Step 1 -->
                        <div class="rg-step-h">
                            <div class="rg-step-num rg-step-num-1">1</div>
                            <div>
                                <h2 class="rg-step-title">البيانات الشخصية</h2>
                                <small class="rg-step-sub">أدخل بياناتك الأساسية</small>
                            </div>
                        </div>

                        <div class="row g-3 mb-2">
                            <div class="col-md-6">
                                <label class="rg-label" asp-for="FullName">
                                    <i class="fas fa-user" aria-hidden="true"></i>
                                    الاسم الكامل <span class="text-danger" aria-hidden="true">*</span>
                                </label>
                                <input asp-for="FullName" class="rg-input"
                                       placeholder="أدخل اسمك الكامل" autocomplete="name" />
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="rg-label" asp-for="NationalId">
                                    <i class="fas fa-id-card" aria-hidden="true"></i>
                                    الرقم القومي <span class="text-danger" aria-hidden="true">*</span>
                                </label>
                                <input asp-for="NationalId" class="rg-input"
                                       placeholder="14 رقم" maxlength="14" dir="ltr"
                                       inputmode="numeric" autocomplete="off"
                                       data-digits="14" />
                                <div class="rg-help" data-help-for="NationalId">
                                    عدد الأرقام: <strong>0</strong> / 14
                                </div>
                                <span asp-validation-for="NationalId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="rg-label" asp-for="PhoneNumber">
                                    <i class="fas fa-mobile-screen" aria-hidden="true"></i>
                                    رقم الموبايل <span class="text-danger" aria-hidden="true">*</span>
                                </label>
                                <input asp-for="PhoneNumber" class="rg-input"
                                       placeholder="11 رقم" maxlength="11" dir="ltr"
                                       inputmode="numeric" autocomplete="tel"
                                       data-digits="11" />
                                <div class="rg-help" data-help-for="PhoneNumber">
                                    عدد الأرقام: <strong>0</strong> / 11
                                </div>
                                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr class="rg-divider" />

                        <!-- Step 2 -->
                        <div class="rg-step-h">
                            <div class="rg-step-num rg-step-num-2">2</div>
                            <div>
                                <h2 class="rg-step-title">المستوى والشعبة</h2>
                                <small class="rg-step-sub">حدد مستواك وشعبتك</small>
                            </div>
                        </div>

                        <div class="row g-3 mb-2">
                            <div class="col-md-6">
                                <label class="rg-label" asp-for="LevelId">
                                    <i class="fas fa-layer-group" aria-hidden="true"></i>
                                    المستوى <span class="text-danger" aria-hidden="true">*</span>
                                </label>
                                <select asp-for="LevelId" class="rg-select form-select">
                                    <option value="">-- اختر المستوى --</option>
                                    @foreach (var level in Model.Levels)
                                    {
                                        <option value="@level.Id">@level.Name</option>
                                    }
                                </select>
                                <span asp-validation-for="LevelId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="rg-label" asp-for="DivisionId">
                                    <i class="fas fa-users" aria-hidden="true"></i>
                                    الشعبة / القسم <span class="text-danger" aria-hidden="true">*</span>
                                </label>
                                <select asp-for="DivisionId" class="rg-select form-select">
                                    <option value="">-- اختر الشعبة --</option>
                                    @foreach (var division in Model.Divisions)
                                    {
                                        <option value="@division.Id">@division.Name</option>
                                    }
                                </select>
                                <span asp-validation-for="DivisionId" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr class="rg-divider" />

                        <!-- Step 3 -->
                        <div class="rg-step-h">
                            <div class="rg-step-num rg-step-num-3">3</div>
                            <div>
                                <h2 class="rg-step-title">المواد الدراسية</h2>
                                <small class="rg-step-sub">اختر عدد المواد ثم أدخل أسماءها</small>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="rg-label" asp-for="SubjectCount">
                                    <i class="fas fa-list-ol" aria-hidden="true"></i>
                                    عدد المواد <span class="text-danger" aria-hidden="true">*</span>
                                </label>
                                <select asp-for="SubjectCount" class="rg-select form-select" id="rg-subjectCount">
                                    <option value="1">مادة واحدة</option>
                                    <option value="2">مادتان</option>
                                    <option value="3">ثلاث مواد</option>
                                    <option value="4">أربع مواد</option>
                                    <option value="5">خمس مواد</option>
                                </select>
                            </div>

                            <div class="col-md-8">
                                <div class="rg-subjects" id="rg-subjectsContainer">
                                    <div class="rg-subject-box" data-subject-index="1">
                                        <label class="rg-label" asp-for="Subject1">
                                            <span class="rg-icon-sub rg-icon-1" aria-hidden="true">1</span>
                                            المادة الأولى <span class="text-danger" aria-hidden="true">*</span>
                                        </label>
                                        <input asp-for="Subject1" class="rg-input"
                                               placeholder="أدخل اسم المادة الأولى" />
                                        <span asp-validation-for="Subject1" class="text-danger small"></span>
                                    </div>

                                    <div class="rg-subject-box" data-subject-index="2" hidden>
                                        <label class="rg-label" asp-for="Subject2">
                                            <span class="rg-icon-sub rg-icon-2" aria-hidden="true">2</span>
                                            المادة الثانية
                                        </label>
                                        <input asp-for="Subject2" class="rg-input"
                                               placeholder="أدخل اسم المادة الثانية" />
                                    </div>

                                    <div class="rg-subject-box" data-subject-index="3" hidden>
                                        <label class="rg-label" asp-for="Subject3">
                                            <span class="rg-icon-sub rg-icon-3" aria-hidden="true">3</span>
                                            المادة الثالثة
                                        </label>
                                        <input asp-for="Subject3" class="rg-input"
                                               placeholder="أدخل اسم المادة الثالثة" />
                                    </div>

                                    <div class="rg-subject-box" data-subject-index="4" hidden>
                                        <label class="rg-label" asp-for="Subject4">
                                            <span class="rg-icon-sub rg-icon-4" aria-hidden="true">4</span>
                                            المادة الرابعة
                                        </label>
                                        <input asp-for="Subject4" class="rg-input"
                                               placeholder="أدخل اسم المادة الرابعة" />
                                    </div>

                                    <div class="rg-subject-box" data-subject-index="5" hidden>
                                        <label class="rg-label" asp-for="Subject5">
                                            <span class="rg-icon-sub rg-icon-5" aria-hidden="true">5</span>
                                            المادة الخامسة
                                        </label>
                                        <input asp-for="Subject5" class="rg-input"
                                               placeholder="أدخل اسم المادة الخامسة" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Submit -->
                        <div class="rg-actions">
                            <button type="submit" class="rg-btn" id="rg-submit">
                                <span class="rg-spinner" aria-hidden="true"></span>
                                <i class="fas fa-circle-check rg-btn-icon" aria-hidden="true"></i>
                                <span>إتمام التسجيل</span>
                            </button>
                        </div>
                    </form>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            'use strict';

            // ====== أرقام عربية → إنجليزية + تنظيف ======
            var arabicMap = { '٠':'0','١':'1','٢':'2','٣':'3','٤':'4','٥':'5','٦':'6','٧':'7','٨':'8','٩':'9',
                              '۰':'0','۱':'1','۲':'2','۳':'3','۴':'4','۵':'5','۶':'6','۷':'7','۸':'8','۹':'9' };
            function digitsOnly(v, max){
                var s = String(v || '')
                    .replace(/[٠-٩۰-۹]/g, function (d){ return arabicMap[d] || d; })
                    .replace(/\D/g, '');
                if (max) s = s.slice(0, max);
                return s;
            }

            // ====== Auto-format لكل input بـ data-digits ======
            document.querySelectorAll('.rg-input[data-digits]').forEach(function (input) {
                var max  = parseInt(input.getAttribute('data-digits'), 10);
                var name = input.getAttribute('name') || input.id;
                var help = document.querySelector('[data-help-for="' + name + '"]');

                function setHelpCount(n){
                    if (!help) return;
                    while (help.firstChild) help.removeChild(help.firstChild);
                    help.appendChild(document.createTextNode('عدد الأرقام: '));
                    var s = document.createElement('strong');
                    s.textContent = String(n);
                    help.appendChild(s);
                    help.appendChild(document.createTextNode(' / ' + max));
                    if (n === max){
                        help.classList.add('is-ok');
                        input.classList.add('is-valid');
                        input.classList.remove('is-invalid');
                    } else {
                        help.classList.remove('is-ok');
                        input.classList.remove('is-valid');
                        if (n > 0) input.classList.add('is-invalid');
                        else input.classList.remove('is-invalid');
                    }
                }

                input.addEventListener('input', function () {
                    input.value = digitsOnly(input.value, max);
                    setHelpCount(input.value.length);
                });
                input.addEventListener('paste', function (e) {
                    try {
                        var pasted = (e.clipboardData || window.clipboardData).getData('text');
                        e.preventDefault();
                        input.value = digitsOnly(input.value + pasted, max);
                        setHelpCount(input.value.length);
                    } catch (err) { /* تجاهل */ }
                });
                setHelpCount(input.value.length);
            });

            // ====== إظهار/إخفاء حقول المواد (آمن وبدون أخطاء) ======
            var subjectCount = document.getElementById('rg-subjectCount');
            var boxes = Array.prototype.slice.call(
                document.querySelectorAll('#rg-subjectsContainer .rg-subject-box'));

            function updateSubjects(){
                if (!subjectCount) return;
                var n = parseInt(subjectCount.value, 10) || 1;
                boxes.forEach(function (box) {
                    var idx = parseInt(box.getAttribute('data-subject-index'), 10) || 0;
                    if (idx <= n){
                        box.hidden = false;
                    } else {
                        box.hidden = true;
                        var inp = box.querySelector('input');
                        if (inp) inp.value = '';
                    }
                });
            }
            if (subjectCount){
                subjectCount.addEventListener('change', updateSubjects);
                updateSubjects();
            }

            // ====== منع double-submit + حالة loading ======
            var form = document.getElementById('rg-form');
            var btn  = document.getElementById('rg-submit');
            if (form && btn){
                form.addEventListener('submit', function () {
                    btn.classList.add('is-loading');
                    btn.setAttribute('disabled', 'disabled');
                });
            }
        })();
    </script>
}
