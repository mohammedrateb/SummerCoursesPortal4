@*
    ═══════════════════════════════════════════════════════════════
      Admin/Auth/ChangePassword.cshtml — Indigo Command Center Theme
      • نفس هوية لوحة الإدارة: Indigo + Cyan + Magenta + Purple.
      • Class prefix: acp-* (Admin Change Password).
      • Password strength meter + show/hide toggle.
      • Success TempData alert + ModelState errors.
      • addEventListener (مفيش inline onclick).
      • صفر تعديل في الـ Backend.
    ═══════════════════════════════════════════════════════════════
*@
@model WebApplication1.ViewModels.Admin.ChangePasswordViewModel
@{
    ViewData["Title"] = "تغيير كلمة المرور";
    Layout = "_Layout";
}

<style>
    .acp-scope {
        --acp-primary:   #4F46E5;
        --acp-accent:    #06B6D4;
        --acp-magenta:   #EC4899;
        --acp-purple:    #8B5CF6;
        --acp-success:   #10B981;
        --acp-danger:    #EF4444;
        --acp-warning:   #F59E0B;
        --acp-text:      #0F172A;
        --acp-muted:     #64748B;
        --acp-border:    #E2E8F0;
        --acp-ease:      cubic-bezier(.22,.61,.36,1);
        --acp-grad:      linear-gradient(135deg, #4F46E5 0%, #06B6D4 100%);
        --acp-grad-dark: linear-gradient(135deg, #1E1B4B 0%, #0F172A 100%);
    }

    @@keyframes acp-up    { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
    @@keyframes acp-shake { 0%, 100% { transform: translateX(0); } 20%, 60% { transform: translateX(-5px); } 40%, 80% { transform: translateX(5px); } }
    @@keyframes acp-drain { from { transform: scaleX(1); } to { transform: scaleX(0); } }

    /* ═══ Layout ═══ */
    .acp-wrap {
        max-width: 520px;
        margin: 2rem auto;
        animation: acp-up .45s var(--acp-ease) both;
    }

    /* ═══ Card ═══ */
    .acp-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 16px 48px -12px rgba(79, 70, 229, .22);
        overflow: hidden;
        position: relative;
    }
    .acp-card-header {
        background: var(--acp-grad-dark);
        padding: 1.75rem 2rem;
        display: flex;
        align-items: center;
        gap: 14px;
        position: relative;
        overflow: hidden;
    }
    .acp-card-header::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
            radial-gradient(60% 60% at 80% 20%, rgba(255,255,255,.10), transparent 60%),
            radial-gradient(50% 50% at 10% 90%, rgba(79,70,229,.25), transparent 60%);
        pointer-events: none;
    }
    .acp-header-icon {
        width: 52px; height: 52px;
        border-radius: 14px;
        background: var(--acp-grad);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.3rem;
        color: #fff;
        flex-shrink: 0;
        box-shadow: 0 8px 20px -6px rgba(79, 70, 229, .6);
        position: relative; z-index: 1;
    }
    .acp-header-text { position: relative; z-index: 1; }
    .acp-header-title {
        font-weight: 800;
        font-size: 1.2rem;
        color: #fff;
        margin: 0 0 3px;
    }
    .acp-header-sub {
        font-size: .82rem;
        color: rgba(255, 255, 255, .65);
        margin: 0;
    }
    .acp-card-body {
        padding: 2rem;
    }

    /* ═══ Alerts ═══ */
    .acp-alert {
        border: none;
        border-radius: 14px;
        padding: .9rem 1.1rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 1.5rem;
        position: relative;
        overflow: hidden;
    }
    .acp-alert::before {
        content: "";
        position: absolute;
        right: 0; top: 0; bottom: 0;
        width: 5px;
    }
    .acp-alert-success {
        background: linear-gradient(135deg, #ECFDF5, #D1FAE5);
        color: #065F46;
        animation: acp-up .35s var(--acp-ease) both;
    }
    .acp-alert-success::before { background: var(--acp-success); }

    .acp-alert-error {
        background: linear-gradient(135deg, #FEF2F2, #FEE2E2);
        color: #991B1B;
        animation: acp-shake .45s ease;
    }
    .acp-alert-error::before { background: var(--acp-danger); }

    .acp-alert-close {
        margin-right: auto;
        margin-left: 0;
        background: transparent;
        border: none;
        cursor: pointer;
        color: inherit;
        font-size: 1.25rem;
        font-weight: 900;
        opacity: .5;
        line-height: 1;
        padding: 0 2px;
        flex-shrink: 0;
        transition: opacity .2s ease;
        font-family: sans-serif;
    }
    .acp-alert-close:hover { opacity: 1; }

    .acp-alert-drain {
        position: absolute;
        bottom: 0; left: 0; right: 0;
        height: 3px;
        background: currentColor;
        opacity: .2;
        border-radius: 0 0 14px 14px;
        transform-origin: right center;
        animation: acp-drain 5s linear forwards;
    }

    /* ═══ Form fields ═══ */
    .acp-field { margin-bottom: 1.25rem; }
    .acp-label {
        display: flex;
        align-items: center;
        gap: 7px;
        font-weight: 700;
        font-size: .9rem;
        color: var(--acp-text);
        margin-bottom: .5rem;
    }
    .acp-label i { color: var(--acp-primary); width: 14px; text-align: center; }

    .acp-input-wrap { position: relative; }
    .acp-input {
        width: 100%;
        border-radius: 12px;
        border: 2px solid var(--acp-border);
        padding: 12px 44px 12px 14px;
        font-family: 'Cairo', sans-serif;
        font-size: .95rem;
        background: #F8FAFC;
        color: var(--acp-text);
        transition: border-color .25s ease, background .25s ease, box-shadow .25s ease;
    }
    .acp-input:focus {
        outline: none;
        background: #fff;
        border-color: var(--acp-primary);
        box-shadow: 0 0 0 4px rgba(79, 70, 229, .15);
    }
    .acp-input.is-invalid {
        border-color: var(--acp-danger);
        box-shadow: 0 0 0 4px rgba(239, 68, 68, .12);
    }

    .acp-eye-btn {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        background: transparent;
        border: none;
        color: var(--acp-muted);
        cursor: pointer;
        padding: 4px;
        font-size: .9rem;
        transition: color .2s ease;
        line-height: 1;
    }
    .acp-eye-btn:hover { color: var(--acp-primary); }

    /* ═══ Strength meter ═══ */
    .acp-strength-wrap { margin-top: 8px; }
    .acp-strength-bar {
        height: 5px;
        border-radius: 50px;
        background: var(--acp-border);
        overflow: hidden;
        margin-bottom: 5px;
    }
    .acp-strength-fill {
        height: 100%;
        border-radius: 50px;
        width: 0%;
        transition: width .35s ease, background .35s ease;
    }
    .acp-strength-label {
        font-size: .75rem;
        font-weight: 700;
        color: var(--acp-muted);
    }

    /* ═══ Hint ═══ */
    .acp-hint {
        font-size: .78rem;
        color: var(--acp-muted);
        margin-top: 5px;
        display: flex;
        align-items: center;
        gap: 5px;
    }
    .acp-hint i { color: var(--acp-accent); }

    /* ═══ Match indicator ═══ */
    .acp-match {
        font-size: .78rem;
        font-weight: 700;
        margin-top: 5px;
        display: flex;
        align-items: center;
        gap: 5px;
        min-height: 18px;
    }
    .acp-match.is-ok    { color: var(--acp-success); }
    .acp-match.is-bad   { color: var(--acp-danger); }
    .acp-match.is-empty { color: transparent; }

    /* ═══ Divider ═══ */
    .acp-divider {
        height: 1px;
        background: var(--acp-border);
        margin: 1.5rem 0;
    }

    /* ═══ Submit button ═══ */
    .acp-btn {
        width: 100%;
        padding: .9rem 1.5rem;
        border-radius: 14px;
        border: none;
        background: var(--acp-grad);
        color: #fff;
        font-weight: 800;
        font-size: .95rem;
        font-family: 'Cairo', sans-serif;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 9px;
        box-shadow: 0 10px 26px -8px rgba(79, 70, 229, .55);
        position: relative;
        overflow: hidden;
        transition: transform .25s var(--acp-ease), box-shadow .25s ease, opacity .2s;
    }
    .acp-btn::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(120deg, transparent 30%, rgba(255,255,255,.25) 50%, transparent 70%);
        transform: translateX(-100%);
        transition: transform .7s ease;
    }
    .acp-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 14px 32px -8px rgba(79, 70, 229, .7); }
    .acp-btn:hover:not(:disabled)::after { transform: translateX(100%); }
    .acp-btn:disabled { opacity: .65; cursor: not-allowed; }

    @@keyframes acp-spin { to { transform: rotate(360deg); } }
    .acp-spinner {
        display: none;
        width: 16px; height: 16px;
        border: 2px solid rgba(255,255,255,.4);
        border-top-color: #fff;
        border-radius: 50%;
        animation: acp-spin .7s linear infinite;
        flex-shrink: 0;
    }
    .acp-btn.is-loading .acp-spinner { display: block; }
    .acp-btn.is-loading .acp-btn-icon { display: none; }

    @@media (prefers-reduced-motion: reduce) {
        .acp-scope *, .acp-scope *::before, .acp-scope *::after {
            animation: none !important;
            transition: none !important;
        }
    }
</style>

<div class="acp-scope">
    <div class="acp-wrap">

        @* ── Success Alert ── *@
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="acp-alert acp-alert-success" role="status" id="acp-success-alert">
                <i class="fas fa-circle-check" aria-hidden="true"></i>
                <span>@TempData["SuccessMessage"]</span>
                <button type="button" class="acp-alert-close" aria-label="إغلاق">×</button>
                <span class="acp-alert-drain" aria-hidden="true"></span>
            </div>
        }

        @* ── Error Alert ── *@
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="acp-alert acp-alert-error" role="alert">
                <i class="fas fa-circle-exclamation" aria-hidden="true"></i>
                <div>
                    @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@err.ErrorMessage</div>
                    }
                </div>
            </div>
        }

        <div class="acp-card">

            @* ── Header ── *@
            <div class="acp-card-header">
                <div class="acp-header-icon" aria-hidden="true">
                    <i class="fas fa-key"></i>
                </div>
                <div class="acp-header-text">
                    <h1 class="acp-header-title">تغيير كلمة المرور</h1>
                    <p class="acp-header-sub">اختر كلمة مرور قوية لا تشاركها مع أحد</p>
                </div>
            </div>

            @* ── Body ── *@
            <div class="acp-card-body">
                <form asp-area="Admin"
                      asp-controller="Auth"
                      asp-action="ChangePassword"
                      method="post"
                      id="acp-form"
                      novalidate>
                    @Html.AntiForgeryToken()

                    @* ── كلمة المرور الحالية ── *@
                    <div class="acp-field">
                        <label class="acp-label" for="CurrentPassword">
                            <i class="fas fa-lock-open" aria-hidden="true"></i>
                            <span asp-for="CurrentPassword">كلمة المرور الحالية</span>
                        </label>
                        <div class="acp-input-wrap">
                            <input asp-for="CurrentPassword"
                                   id="CurrentPassword"
                                   class="acp-input"
                                   type="password"
                                   autocomplete="current-password"
                                   placeholder="أدخل كلمة مرورك الحالية" />
                            <button type="button"
                                    class="acp-eye-btn"
                                    data-target="CurrentPassword"
                                    aria-label="إظهار / إخفاء كلمة المرور">
                                <i class="fas fa-eye" aria-hidden="true"></i>
                            </button>
                        </div>
                    </div>

                    <div class="acp-divider" aria-hidden="true"></div>

                    @* ── كلمة المرور الجديدة ── *@
                    <div class="acp-field">
                        <label class="acp-label" for="NewPassword">
                            <i class="fas fa-lock" aria-hidden="true"></i>
                            <span asp-for="NewPassword">كلمة المرور الجديدة</span>
                        </label>
                        <div class="acp-input-wrap">
                            <input asp-for="NewPassword"
                                   id="NewPassword"
                                   class="acp-input"
                                   type="password"
                                   autocomplete="new-password"
                                   placeholder="8 أحرف على الأقل" />
                            <button type="button"
                                    class="acp-eye-btn"
                                    data-target="NewPassword"
                                    aria-label="إظهار / إخفاء كلمة المرور">
                                <i class="fas fa-eye" aria-hidden="true"></i>
                            </button>
                        </div>
                        <div class="acp-strength-wrap" id="acp-strength-wrap" aria-live="polite">
                            <div class="acp-strength-bar">
                                <div class="acp-strength-fill" id="acp-strength-fill"></div>
                            </div>
                            <span class="acp-strength-label" id="acp-strength-label"></span>
                        </div>
                        <p class="acp-hint">
                            <i class="fas fa-circle-info" aria-hidden="true"></i>
                            يُفضَّل أن تحتوي على أحرف وأرقام ورموز
                        </p>
                    </div>

                    @* ── تأكيد كلمة المرور ── *@
                    <div class="acp-field">
                        <label class="acp-label" for="ConfirmPassword">
                            <i class="fas fa-shield-check" aria-hidden="true"></i>
                            <span asp-for="ConfirmPassword">تأكيد كلمة المرور</span>
                        </label>
                        <div class="acp-input-wrap">
                            <input asp-for="ConfirmPassword"
                                   id="ConfirmPassword"
                                   class="acp-input"
                                   type="password"
                                   autocomplete="new-password"
                                   placeholder="أعد كتابة كلمة المرور الجديدة" />
                            <button type="button"
                                    class="acp-eye-btn"
                                    data-target="ConfirmPassword"
                                    aria-label="إظهار / إخفاء كلمة المرور">
                                <i class="fas fa-eye" aria-hidden="true"></i>
                            </button>
                        </div>
                        <div class="acp-match is-empty" id="acp-match" aria-live="polite">
                            <i class="fas fa-circle-check" aria-hidden="true" id="acp-match-icon"></i>
                            <span id="acp-match-text"></span>
                        </div>
                    </div>

                    <button type="submit" class="acp-btn" id="acp-submit">
                        <span class="acp-spinner" aria-hidden="true"></span>
                        <i class="fas fa-floppy-disk acp-btn-icon" aria-hidden="true"></i>
                        <span>حفظ كلمة المرور الجديدة</span>
                    </button>

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    'use strict';

    // ── Show / Hide password ──────────────────────────────────────
    document.querySelectorAll('.acp-eye-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var targetId = btn.getAttribute('data-target');
            var input    = document.getElementById(targetId);
            var icon     = btn.querySelector('i');
            if (!input || !icon) return;

            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        });
    });

    // ── Password Strength Meter ───────────────────────────────────
    var newPassInput    = document.getElementById('NewPassword');
    var strengthFill    = document.getElementById('acp-strength-fill');
    var strengthLabel   = document.getElementById('acp-strength-label');

    var strengthLevels = [
        { label: 'ضعيفة جداً', color: '#EF4444', width: '15%' },
        { label: 'ضعيفة',      color: '#F97316', width: '35%' },
        { label: 'متوسطة',     color: '#F59E0B', width: '60%' },
        { label: 'جيدة',       color: '#06B6D4', width: '80%' },
        { label: 'قوية',       color: '#10B981', width: '100%' }
    ];

    function calcStrength(pwd) {
        if (!pwd) return -1;
        var score = 0;
        if (pwd.length >= 8)  score++;
        if (pwd.length >= 12) score++;
        if (/[A-Z]/.test(pwd) && /[a-z]/.test(pwd)) score++;
        if (/[0-9]/.test(pwd)) score++;
        if (/[^A-Za-z0-9]/.test(pwd)) score++;
        return Math.min(score, 4);
    }

    if (newPassInput && strengthFill && strengthLabel) {
        newPassInput.addEventListener('input', function () {
            var score = calcStrength(this.value);
            if (score < 0) {
                strengthFill.style.width = '0%';
                strengthLabel.textContent = '';
                return;
            }
            var lvl = strengthLevels[score];
            strengthFill.style.width      = lvl.width;
            strengthFill.style.background = lvl.color;
            strengthLabel.textContent     = 'قوة كلمة المرور: ' + lvl.label;
            strengthLabel.style.color     = lvl.color;

            // also re-check match
            checkMatch();
        });
    }

    // ── Confirm match indicator ───────────────────────────────────
    var confirmInput = document.getElementById('ConfirmPassword');
    var matchEl      = document.getElementById('acp-match');
    var matchIcon    = document.getElementById('acp-match-icon');
    var matchText    = document.getElementById('acp-match-text');

    function checkMatch() {
        if (!confirmInput || !newPassInput || !matchEl) return;
        var a = newPassInput.value;
        var b = confirmInput.value;

        if (!b) {
            matchEl.className = 'acp-match is-empty';
            matchText.textContent = '';
            return;
        }
        if (a === b) {
            matchEl.className = 'acp-match is-ok';
            matchIcon.className = 'fas fa-circle-check';
            matchText.textContent = 'كلمتا المرور متطابقتان';
        } else {
            matchEl.className = 'acp-match is-bad';
            matchIcon.className = 'fas fa-circle-xmark';
            matchText.textContent = 'كلمتا المرور غير متطابقتين';
        }
    }

    if (confirmInput) {
        confirmInput.addEventListener('input', checkMatch);
    }

    // ── Loading state on submit ───────────────────────────────────
    var form      = document.getElementById('acp-form');
    var submitBtn = document.getElementById('acp-submit');

    if (form && submitBtn) {
        form.addEventListener('submit', function () {
            submitBtn.classList.add('is-loading');
            submitBtn.setAttribute('disabled', 'disabled');
        });
    }

    // ── Success alert auto-dismiss ────────────────────────────────
    var successAlert = document.getElementById('acp-success-alert');
    if (successAlert) {
        var timer = setTimeout(function () { dismissAlert(successAlert); }, 5000);
        var closeBtn = successAlert.querySelector('.acp-alert-close');
        if (closeBtn) {
            closeBtn.addEventListener('click', function () {
                clearTimeout(timer);
                dismissAlert(successAlert);
            });
        }
    }

    function dismissAlert(el) {
        el.style.transition = 'opacity .4s ease, transform .4s ease, max-height .4s ease, margin-bottom .4s ease, padding .4s ease';
        el.style.opacity = '0';
        el.style.transform = 'translateX(20px)';
        el.style.maxHeight = el.offsetHeight + 'px';
        setTimeout(function () {
            el.style.maxHeight = '0';
            el.style.marginBottom = '0';
            el.style.paddingTop = '0';
            el.style.paddingBottom = '0';
            el.style.overflow = 'hidden';
            setTimeout(function () { if (el.parentNode) el.parentNode.removeChild(el); }, 420);
        }, 400);
    }

}());
</script>
}
