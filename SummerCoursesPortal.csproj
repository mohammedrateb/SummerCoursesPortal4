		</PackageReference>
		<PackageReference Include="Microsoft.VisualStudio.Web.CodeGeneration.Design" Version="10.0.2" />
	</ItemGroup>

	<ItemGroup>
		<Folder Include="wwwroot\uploads\" />
		<Folder Include="wwwroot\downloads\" />
	</ItemGroup>

</Project>
